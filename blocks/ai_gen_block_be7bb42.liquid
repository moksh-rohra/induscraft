{% doc %}
  @prompt
    A magazine style brochure, Can I get a little more blocks. I want to introduce my brand called Moakuzai which is a select collection of exclusive products made in oak. Then it should be followed by the segmented themes, the first line of products are in a collection called Yuki. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-brochure-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .ai-magazine-brochure__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-brochure__header-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: 40px;
  }

  .ai-magazine-brochure__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .ai-magazine-brochure__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    font-weight: 400;
    line-height: 1.6;
  }

  .ai-magazine-brochure__brand-intro-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 60px;
    padding: 60px 40px;
    background-color: {{ block.settings.brand_bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-magazine-brochure__brand-content-{{ ai_gen_id }} {
    grid-column: span 7;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ai-magazine-brochure__brand-image-{{ ai_gen_id }} {
    grid-column: span 5;
  }

  .ai-magazine-brochure__brand-logo-{{ ai_gen_id }} {
    max-width: 200px;
    margin-bottom: 24px;
  }

  .ai-magazine-brochure__brand-name-{{ ai_gen_id }} {
    font-size: 56px;
    font-weight: 700;
    color: {{ block.settings.brand_text_color }};
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .ai-magazine-brochure__brand-tagline-{{ ai_gen_id }} {
    font-size: 20px;
    color: {{ block.settings.brand_text_color }};
    margin: 0 0 24px;
    opacity: 0.8;
    line-height: 1.6;
  }

  .ai-magazine-brochure__brand-description-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.brand_text_color }};
    margin: 0 0 32px;
    line-height: 1.8;
    opacity: 0.9;
  }

  .ai-magazine-brochure__brand-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-magazine-brochure__brand-img-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-brochure__brand-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-brochure__brand-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-magazine-brochure__section-header-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    margin-bottom: 32px;
  }

  .ai-magazine-brochure__section-title-{{ ai_gen_id }} {
    font-size: 36px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .ai-magazine-brochure__section-subtitle-{{ ai_gen_id }} {
    font-size: 18px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-magazine-brochure__feature-large-{{ ai_gen_id }} {
    grid-column: span 8;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.card_bg_color }};
  }

  .ai-magazine-brochure__feature-small-{{ ai_gen_id }} {
    grid-column: span 4;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.card_bg_color }};
  }

  .ai-magazine-brochure__feature-medium-{{ ai_gen_id }} {
    grid-column: span 6;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.card_bg_color }};
  }

  .ai-magazine-brochure__feature-third-{{ ai_gen_id }} {
    grid-column: span 4;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.card_bg_color }};
  }

  .ai-magazine-brochure__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 75%;
    overflow: hidden;
  }

  .ai-magazine-brochure__image-wrapper--tall-{{ ai_gen_id }} {
    padding-bottom: 133%;
  }

  .ai-magazine-brochure__image-wrapper--square-{{ ai_gen_id }} {
    padding-bottom: 100%;
  }

  .ai-magazine-brochure__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .ai-magazine-brochure__feature-large-{{ ai_gen_id }}:hover .ai-magazine-brochure__image-{{ ai_gen_id }},
  .ai-magazine-brochure__feature-small-{{ ai_gen_id }}:hover .ai-magazine-brochure__image-{{ ai_gen_id }},
  .ai-magazine-brochure__feature-medium-{{ ai_gen_id }}:hover .ai-magazine-brochure__image-{{ ai_gen_id }},
  .ai-magazine-brochure__feature-third-{{ ai_gen_id }}:hover .ai-magazine-brochure__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-magazine-brochure__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-brochure__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-magazine-brochure__content-{{ ai_gen_id }} {
    padding: 24px;
  }

  .ai-magazine-brochure__category-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ block.settings.accent_color }};
    margin-bottom: 12px;
  }

  .ai-magazine-brochure__heading-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .ai-magazine-brochure__feature-large-{{ ai_gen_id }} .ai-magazine-brochure__heading-{{ ai_gen_id }} {
    font-size: 32px;
  }

  .ai-magazine-brochure__description-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    line-height: 1.6;
    opacity: 0.8;
  }

  .ai-magazine-brochure__link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.accent_color }};
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .ai-magazine-brochure__link-{{ ai_gen_id }}:hover {
    gap: 12px;
  }

  .ai-magazine-brochure__link-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-magazine-brochure__link-{{ ai_gen_id }}:hover .ai-magazine-brochure__link-arrow-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-magazine-brochure__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-magazine-brochure__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 989px) {
    .ai-magazine-brochure__brand-content-{{ ai_gen_id }},
    .ai-magazine-brochure__brand-image-{{ ai_gen_id }} {
      grid-column: span 12;
    }

    .ai-magazine-brochure__brand-intro-{{ ai_gen_id }} {
      padding: 40px 24px;
    }

    .ai-magazine-brochure__brand-name-{{ ai_gen_id }} {
      font-size: 40px;
    }

    .ai-magazine-brochure__feature-large-{{ ai_gen_id }},
    .ai-magazine-brochure__feature-small-{{ ai_gen_id }},
    .ai-magazine-brochure__feature-medium-{{ ai_gen_id }},
    .ai-magazine-brochure__feature-third-{{ ai_gen_id }} {
      grid-column: span 12;
    }

    .ai-magazine-brochure__image-wrapper--tall-{{ ai_gen_id }} {
      padding-bottom: 75%;
    }

    .ai-magazine-brochure__feature-large-{{ ai_gen_id }} .ai-magazine-brochure__heading-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-magazine-brochure__section-title-{{ ai_gen_id }} {
      font-size: 28px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-brochure-{{ ai_gen_id }} {
      padding: 20px 16px;
    }

    .ai-magazine-brochure__grid-{{ ai_gen_id }} {
      gap: 16px;
      margin-bottom: 16px;
    }

    .ai-magazine-brochure__brand-intro-{{ ai_gen_id }} {
      padding: 32px 20px;
      margin-bottom: 40px;
    }

    .ai-magazine-brochure__brand-name-{{ ai_gen_id }} {
      font-size: 32px;
    }

    .ai-magazine-brochure__brand-tagline-{{ ai_gen_id }} {
      font-size: 16px;
    }

    .ai-magazine-brochure__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-magazine-brochure__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.85 }}px;
    }

    .ai-magazine-brochure__content-{{ ai_gen_id }} {
      padding: 16px;
    }

    .ai-magazine-brochure__heading-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ai-magazine-brochure__section-title-{{ ai_gen_id }} {
      font-size: 24px;
    }
  }
{% endstyle %}

<div class="ai-magazine-brochure-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.main_title != blank or block.settings.main_subtitle != blank %}
    <div class="ai-magazine-brochure__header-{{ ai_gen_id }}">
      {% if block.settings.main_title != blank %}
        <h2 class="ai-magazine-brochure__title-{{ ai_gen_id }}">{{ block.settings.main_title }}</h2>
      {% endif %}
      {% if block.settings.main_subtitle != blank %}
        <p class="ai-magazine-brochure__subtitle-{{ ai_gen_id }}">{{ block.settings.main_subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if block.settings.show_brand_intro %}
    <div class="ai-magazine-brochure__grid-{{ ai_gen_id }}">
      <div class="ai-magazine-brochure__brand-intro-{{ ai_gen_id }}">
        <div class="ai-magazine-brochure__brand-content-{{ ai_gen_id }}">
          {% if block.settings.brand_logo %}
            <img
              src="{{ block.settings.brand_logo | image_url: width: 400 }}"
              alt="{{ block.settings.brand_logo.alt | escape }}"
              loading="lazy"
              class="ai-magazine-brochure__brand-logo-{{ ai_gen_id }}"
            >
          {% endif %}
          {% if block.settings.brand_name != blank %}
            <h2 class="ai-magazine-brochure__brand-name-{{ ai_gen_id }}">{{ block.settings.brand_name }}</h2>
          {% endif %}
          {% if block.settings.brand_tagline != blank %}
            <p class="ai-magazine-brochure__brand-tagline-{{ ai_gen_id }}">{{ block.settings.brand_tagline }}</p>
          {% endif %}
          {% if block.settings.brand_description != blank %}
            <div class="ai-magazine-brochure__brand-description-{{ ai_gen_id }}">{{ block.settings.brand_description }}</div>
          {% endif %}
          {% if block.settings.brand_button_link != blank %}
            <a href="{{ block.settings.brand_button_link }}" class="ai-magazine-brochure__button-{{ ai_gen_id }}">
              {{ block.settings.brand_button_text }}
              <svg class="ai-magazine-brochure__link-arrow-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          {% endif %}
        </div>
        <div class="ai-magazine-brochure__brand-image-{{ ai_gen_id }}">
          <div class="ai-magazine-brochure__brand-image-wrapper-{{ ai_gen_id }}">
            {% if block.settings.brand_image %}
              <img
                src="{{ block.settings.brand_image | image_url: width: 800 }}"
                alt="{{ block.settings.brand_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.brand_image.width }}"
                height="{{ block.settings.brand_image.height }}"
                class="ai-magazine-brochure__brand-img-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-magazine-brochure__brand-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  {% if block.settings.show_collection_section %}
    <div class="ai-magazine-brochure__grid-{{ ai_gen_id }}">
      <div class="ai-magazine-brochure__section-header-{{ ai_gen_id }}">
        {% if block.settings.collection_title != blank %}
          <h3 class="ai-magazine-brochure__section-title-{{ ai_gen_id }}">{{ block.settings.collection_title }}</h3>
        {% endif %}
        {% if block.settings.collection_subtitle != blank %}
          <p class="ai-magazine-brochure__section-subtitle-{{ ai_gen_id }}">{{ block.settings.collection_subtitle }}</p>
        {% endif %}
      </div>

      {% if block.settings.collection_feature_1_enabled %}
        <div class="ai-magazine-brochure__feature-large-{{ ai_gen_id }}">
          <div class="ai-magazine-brochure__image-wrapper-{{ ai_gen_id }}">
            {% if block.settings.collection_feature_1_image %}
              <img
                src="{{ block.settings.collection_feature_1_image | image_url: width: 1200 }}"
                alt="{{ block.settings.collection_feature_1_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.collection_feature_1_image.width }}"
                height="{{ block.settings.collection_feature_1_image.height }}"
                class="ai-magazine-brochure__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-magazine-brochure__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-magazine-brochure__content-{{ ai_gen_id }}">
            {% if block.settings.collection_feature_1_category != blank %}
              <span class="ai-magazine-brochure__category-{{ ai_gen_id }}">{{ block.settings.collection_feature_1_category }}</span>
            {% endif %}
            {% if block.settings.collection_feature_1_title != blank %}
              <h3 class="ai-magazine-brochure__heading-{{ ai_gen_id }}">{{ block.settings.collection_feature_1_title }}</h3>
            {% endif %}
            {% if block.settings.collection_feature_1_description != blank %}
              <div class="ai-magazine-brochure__description-{{ ai_gen_id }}">{{ block.settings.collection_feature_1_description }}</div>
            {% endif %}
            {% if block.settings.collection_feature_1_link != blank %}
              <a href="{{ block.settings.collection_feature_1_link }}" class="ai-magazine-brochure__link-{{ ai_gen_id }}">
                {{ block.settings.collection_feature_1_link_text }}
                <svg class="ai-magazine-brochure__link-arrow-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if block.settings.collection_feature_2_enabled %}
        <div class="ai-magazine-brochure__feature-small-{{ ai_gen_id }}">
          <div class="ai-magazine-brochure__image-wrapper-{{ ai_gen_id }} ai-magazine-brochure__image-wrapper--tall-{{ ai_gen_id }}">
            {% if block.settings.collection_feature_2_image %}
              <img
                src="{{ block.settings.collection_feature_2_image | image_url: width: 600 }}"
                alt="{{ block.settings.collection_feature_2_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.collection_feature_2_image.width }}"
                height="{{ block.settings.collection_feature_2_image.height }}"
                class="ai-magazine-brochure__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-magazine-brochure__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-2' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-magazine-brochure__content-{{ ai_gen_id }}">
            {% if block.settings.collection_feature_2_category != blank %}
              <span class="ai-magazine-brochure__category-{{ ai_gen_id }}">{{ block.settings.collection_feature_2_category }}</span>
            {% endif %}
            {% if block.settings.collection_feature_2_title != blank %}
              <h3 class="ai-magazine-brochure__heading-{{ ai_gen_id }}">{{ block.settings.collection_feature_2_title }}</h3>
            {% endif %}
            {% if block.settings.collection_feature_2_description != blank %}
              <div class="ai-magazine-brochure__description-{{ ai_gen_id }}">{{ block.settings.collection_feature_2_description }}</div>
            {% endif %}
            {% if block.settings.collection_feature_2_link != blank %}
              <a href="{{ block.settings.collection_feature_2_link }}" class="ai-magazine-brochure__link-{{ ai_gen_id }}">
                {{ block.settings.collection_feature_2_link_text }}
                <svg class="ai-magazine-brochure__link-arrow-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-magazine-brochure__grid-{{ ai_gen_id }}">
      {% if block.settings.collection_feature_3_enabled %}
        <div class="ai-magazine-brochure__feature-third-{{ ai_gen_id }}">
          <div class="ai-magazine-brochure__image-wrapper-{{ ai_gen_id }} ai-magazine-brochure__image-wrapper--square-{{ ai_gen_id }}">
            {% if block.settings.collection_feature_3_image %}
              <img
                src="{{ block.settings.collection_feature_3_image | image_url: width: 600 }}"
                alt="{{ block.settings.collection_feature_3_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.collection_feature_3_image.width }}"
                height="{{ block.settings.collection_feature_3_image.height }}"
                class="ai-magazine-brochure__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-magazine-brochure__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-3' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-magazine-brochure__content-{{ ai_gen_id }}">
            {% if block.settings.collection_feature_3_category != blank %}
              <span class="ai-magazine-brochure__category-{{ ai_gen_id }}">{{ block.settings.collection_feature_3_category }}</span>
            {% endif %}
            {% if block.settings.collection_feature_3_title != blank %}
              <h3 class="ai-magazine-brochure__heading-{{ ai_gen_id }}">{{ block.settings.collection_feature_3_title }}</h3>
            {% endif %}
            {% if block.settings.collection_feature_3_description != blank %}
              <div class="ai-magazine-brochure__description-{{ ai_gen_id }}">{{ block.settings.collection_feature_3_description }}</div>
            {% endif %}
            {% if block.settings.collection_feature_3_link != blank %}
              <a href="{{ block.settings.collection_feature_3_link }}" class="ai-magazine-brochure__link-{{ ai_gen_id }}">
                {{ block.settings.collection_feature_3_link_text }}
                <svg class="ai-magazine-brochure__link-arrow-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if block.settings.collection_feature_4_enabled %}
        <div class="ai-magazine-brochure__feature-third-{{ ai_gen_id }}">
          <div class="ai-magazine-brochure__image-wrapper-{{ ai_gen_id }} ai-magazine-brochure__image-wrapper--square-{{ ai_gen_id }}">
            {% if block.settings.collection_feature_4_image %}
              <img
                src="{{ block.settings.collection_feature_4_image | image_url: width: 600 }}"
                alt="{{ block.settings.collection_feature_4_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.collection_feature_4_image.width }}"
                height="{{ block.settings.collection_feature_4_image.height }}"
                class="ai-magazine-brochure__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-magazine-brochure__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-4' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-magazine-brochure__content-{{ ai_gen_id }}">
            {% if block.settings.collection_feature_4_category != blank %}
