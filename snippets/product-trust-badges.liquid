{% comment %}
------------------------------------------------------------------------------
  Snippet: Product Trust Badges
  A row of up to 3 trust badges with icons, title, and optional subtitle.
------------------------------------------------------------------------------
{% endcomment %}

{%- assign icon_color = block.settings.icon_color | default: '#9a8cd8' -%}
{%- assign icon_bg_color = block.settings.icon_bg_color | default: '#efebff' -%}
{%- assign text_color = block.settings.text_color | default: '#1a1a1a' -%}
{%- assign subtext_color = block.settings.subtext_color | default: '#888888' -%}
{%- assign icon_size = block.settings.icon_size | default: 40 -%}
{%- assign icon_size_mobile = block.settings.icon_size_mobile | default: 34 -%}
{%- assign icon_content_spacing_mobile = block.settings.icon_content_spacing_mobile | default: 8 -%}
{%- assign title_font_size_mobile = block.settings.title_font_size_mobile | default: 12 -%}
{%- assign subtitle_font_size_mobile = block.settings.subtitle_font_size_mobile | default: 10 -%}

<style>
  .product-trust-badges-{{ block.id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    padding: {{ block.settings.padding_top | default: 20 }}px 0 {{ block.settings.padding_bottom | default: 20 }}px;
    border-top: {% if block.settings.show_border_top %}1px solid {{ block.settings.border_color | default: '#e5e5e5' }}{% else %}none{% endif %};
    border-bottom: {% if block.settings.show_border_bottom %}1px solid {{ block.settings.border_color | default: '#e5e5e5' }}{% else %}none{% endif %};
    margin-top: {{ block.settings.margin_top | default: 0 }}px;
    margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px;
  }
  .product-trust-badges-{{ block.id }} .trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1 1 0;
    min-width: 100px;
  }
  .product-trust-badges-{{ block.id }} .trust-badge__icon-wrapper {
    width: {{ icon_size }}px;
    height: {{ icon_size }}px;
    border-radius: 50%;
    background-color: {{ icon_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ block.settings.icon_content_spacing | default: 10 }}px;
  }
  .product-trust-badges-{{ block.id }} .trust-badge__icon-wrapper svg {
    width: {{ icon_size | divided_by: 2 }}px;
    height: {{ icon_size | divided_by: 2 }}px;
    color: {{ icon_color }};
    fill: currentColor;
  }
  .product-trust-badges-{{ block.id }} .trust-badge__icon-wrapper img {
    width: {{ icon_size | divided_by: 2 }}px;
    height: {{ icon_size | divided_by: 2 }}px;
    object-fit: contain;
  }
  .product-trust-badges-{{ block.id }} .trust-badge__title {
    font-size: {{ block.settings.title_font_size | default: 14 }}px;
    font-weight: 600;
    color: {{ text_color }};
    line-height: 1.3;
    margin: 0;
  }
  .product-trust-badges-{{ block.id }} .trust-badge__subtitle {
    font-size: {{ block.settings.subtitle_font_size | default: 12 }}px;
    font-weight: 400;
    color: {{ subtext_color }};
    margin-top: 4px;
  }
  @media (max-width: 480px) {
    .product-trust-badges-{{ block.id }} {
      gap: 0.75rem;
    }
    .product-trust-badges-{{ block.id }} .trust-badge__icon-wrapper {
      width: {{ icon_size_mobile }}px;
      height: {{ icon_size_mobile }}px;
      margin-bottom: {{ icon_content_spacing_mobile }}px;
    }
    .product-trust-badges-{{ block.id }} .trust-badge__icon-wrapper svg {
      width: {{ icon_size_mobile | divided_by: 2 }}px;
      height: {{ icon_size_mobile | divided_by: 2 }}px;
    }
    .product-trust-badges-{{ block.id }} .trust-badge__icon-wrapper img {
      width: {{ icon_size_mobile | divided_by: 2 }}px;
      height: {{ icon_size_mobile | divided_by: 2 }}px;
    }
    .product-trust-badges-{{ block.id }} .trust-badge__title {
      font-size: {{ title_font_size_mobile }}px;
    }
    .product-trust-badges-{{ block.id }} .trust-badge__subtitle {
      font-size: {{ subtitle_font_size_mobile }}px;
    }
  }
</style>

<div class="product-trust-badges product-trust-badges-{{ block.id }}" {{ block.shopify_attributes }}>
  {%- comment -%} Badge 1 {%- endcomment -%}
  {%- if block.settings.badge1_title != blank -%}
    <div class="trust-badge">
      <div class="trust-badge__icon-wrapper">
        {%- if block.settings.badge1_icon != blank -%}
          <img src="{{ block.settings.badge1_icon | image_url: width: 80 }}" alt="{{ block.settings.badge1_title | escape }}" width="40" height="40" loading="lazy">
        {%- else -%}
          {%- comment -%} Default shipping truck icon {%- endcomment -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"></rect>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
        {%- endif -%}
      </div>
      <p class="trust-badge__title">{{ block.settings.badge1_title }}</p>
      {%- if block.settings.badge1_subtitle != blank -%}
        <span class="trust-badge__subtitle">{{ block.settings.badge1_subtitle }}</span>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} Badge 2 {%- endcomment -%}
  {%- if block.settings.badge2_title != blank -%}
    <div class="trust-badge">
      <div class="trust-badge__icon-wrapper">
        {%- if block.settings.badge2_icon != blank -%}
          <img src="{{ block.settings.badge2_icon | image_url: width: 80 }}" alt="{{ block.settings.badge2_title | escape }}" width="40" height="40" loading="lazy">
        {%- else -%}
          {%- comment -%} Default users/trusted icon {%- endcomment -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        {%- endif -%}
      </div>
      <p class="trust-badge__title">{{ block.settings.badge2_title }}</p>
      {%- if block.settings.badge2_subtitle != blank -%}
        <span class="trust-badge__subtitle">{{ block.settings.badge2_subtitle }}</span>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} Badge 3 {%- endcomment -%}
  {%- if block.settings.badge3_title != blank -%}
    <div class="trust-badge">
      <div class="trust-badge__icon-wrapper">
        {%- if block.settings.badge3_icon != blank -%}
          <img src="{{ block.settings.badge3_icon | image_url: width: 80 }}" alt="{{ block.settings.badge3_title | escape }}" width="40" height="40" loading="lazy">
        {%- else -%}
          {%- comment -%} Default return/box icon {%- endcomment -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="1 4 1 10 7 10"></polyline>
            <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
          </svg>
        {%- endif -%}
      </div>
      <p class="trust-badge__title">{{ block.settings.badge3_title }}</p>
      {%- if block.settings.badge3_subtitle != blank -%}
        <span class="trust-badge__subtitle">{{ block.settings.badge3_subtitle }}</span>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>
