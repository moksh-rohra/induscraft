{% comment %}
  Renders a Google Review Card
  Accepts:
  - block: {Object} The block object containing settings
{% endcomment %}

<div class="gr-card" {{ block.shopify_attributes }}>
  <div class="gr-card-header">
    {%- if block.settings.author_image != blank -%}
      <img src="{{ block.settings.author_image | image_url: width: 80 }}" 
           alt="{{ block.settings.author_name }}" 
           class="gr-author-img"
           loading="lazy"
           width="40"
           height="40">
    {%- else -%}
        <div class="gr-author-img gr-author-img-placeholder" style="background-color: {{ 'now' | date: '%s' | modulo: 5 | plus: 1 | map: 'timeout' | default: '#689f38' }}">
            {{ block.settings.author_name | slice: 0 | upcase }}
        </div>
    {%- endif -%}

    <div class="gr-author-info">
      <h4 class="gr-author-name">{{ block.settings.author_name }}</h4>
      <span class="gr-post-time">{{ block.settings.time_text }}</span>
    </div>

    <!-- Google G Logo SVG -->
    <svg class="gr-google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.21-1.19-.63z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
    </svg>
  </div>

  <div class="gr-rating">
    {%- for i in (1..block.settings.rating) -%}
        <svg class="gr-star" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
    {%- endfor -%}
    
     <!-- Verified Tick (Rosette Style) -->
     {%- if verified_badge != blank -%}
        <img src="{{ verified_badge | image_url: width: 40 }}" class="gr-verified-badge" width="18" height="18" alt="Verified">
     {%- else -%}
        <!-- Verified Tick (Perfect Center Rosette) -->
        <svg class="gr-verified-badge" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none">
            <!-- 8-point wavy seal -->
            <path fill="#1A73E8" d="M23,12l-1.44-2.51l0.34-2.88l-2.88-0.66L17.89,3.4l-2.88,1.01L12,2.05L9,4.41L6.11,3.4L4.99,5.95 L2.11,6.61l0.34,2.88L1,12l1.44,2.51L2.11,17.4l2.88,0.66l1.13,2.55l2.88-1.01L12,21.95l3-2.35l2.88,1.01l1.13-2.55l2.88-0.66 l-0.34-2.88L23,12z"/>
            <!-- Centered Check (scaled down) -->
            <path fill="white" d="M10.09,16.72l-4.7-4.7l1.41-1.41l3.29,3.29l7.29-7.29l1.41,1.41L10.09,16.72z" transform="translate(12,12) scale(0.75) translate(-12,-12)"/>
        </svg>
     {%- endif -%}
  </div>

  <div class="gr-body-wrapper">
      <div class="gr-text-column">
          <div class="gr-review-text">
            {{ block.settings.text }}
          </div>
          {%- if block.settings.text.size > 120 -%}
            <a class="gr-show-more" onclick="toggleReviewText(this)">Show more</a>
          {%- endif -%}
      </div>

      {%- assign has_image_1 = block.settings.review_image -%}
      {%- assign has_image_2 = block.settings.review_image_2 -%}
      {%- assign has_image_3 = block.settings.review_image_3 -%}

      {%- if has_image_1 or has_image_2 or has_image_3 -%}
        {%- comment -%} Collect all image URLs into a JSON array for gallery navigation {%- endcomment -%}
        {%- capture gallery_images -%}
          [
            {%- if has_image_1 != blank -%}"{{ block.settings.review_image | image_url: width: 800 }}"{%- endif -%}
            {%- if has_image_2 != blank -%}{%- if has_image_1 != blank -%},{%- endif -%}"{{ block.settings.review_image_2 | image_url: width: 800 }}"{%- endif -%}
            {%- if has_image_3 != blank -%}{%- if has_image_1 != blank or has_image_2 != blank -%},{%- endif -%}"{{ block.settings.review_image_3 | image_url: width: 800 }}"{%- endif -%}
          ]
        {%- endcapture -%}

        <div class="gr-review-images-mixed-stack" data-gallery='{{ gallery_images | strip_newlines }}'>
            {%- if has_image_3 != blank -%}
                 <img src="{{ block.settings.review_image_3 | image_url: width: 200 }}" class="gr-stack-img" style="z-index: 3;" data-index="2" onclick="openReviewPopup(event, this)" width="200" height="200" loading="lazy">
            {%- endif -%}
            {%- if has_image_2 != blank -%}
                 <img src="{{ block.settings.review_image_2 | image_url: width: 200 }}" class="gr-stack-img" style="z-index: 2;" data-index="1" onclick="openReviewPopup(event, this)" width="200" height="200" loading="lazy">
            {%- endif -%}
            {%- if has_image_1 != blank -%}
                 <img src="{{ block.settings.review_image | image_url: width: 200 }}" class="gr-stack-img" style="z-index: 1;" data-index="0" onclick="openReviewPopup(event, this)" width="200" height="200" loading="lazy">
            {%- endif -%}
        </div>
      {%- endif -%}
  </div>
</div>
