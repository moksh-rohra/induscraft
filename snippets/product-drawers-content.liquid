{% comment %}
------------------------------------------------------------------------------
  Snippet: Product Drawers Content
  Renders the slide-out drawer panels for all drawers blocks.
------------------------------------------------------------------------------
{% endcomment %}

{%- assign options = blocks | where: 'type', 'options' | first -%}

{%- for drawers in blocks -%}
	{%- if drawers.type == 'drawers' -%}
		{%- comment -%}
			Description variables
		{%- endcomment -%}
		{%- assign description_show = drawers.settings.show_description -%}
		{%- assign description_toggle_text = drawers.settings.description_toggle_text -%}
		{%- assign description_drawer_title = drawers.settings.description_drawer_title -%}

		{%- if description_show
			and description_toggle_text != blank
			and product.description != blank
			and description_drawer_title != blank
		-%}
			{%- assign toggle_id = 'descriptionDrawer-' | append: section.id -%}
			{%- assign product_description = product.description | replace: '<img', '<img loading="lazy"' -%}
			{%- include 'product-form-drawer',
				title: description_drawer_title,
				content: product_description,
				toggle_id: toggle_id,
				class_container: 'product-description-drawer',
				class_body: 'rte-product-drawer rte-product-drawer--description'
			-%}
		{%- endif -%}

		{%- comment -%}
			Shipping & Returns
		{%- endcomment -%}
		{%- assign sr_page = drawers.settings.shipping_and_returns -%}
		{%- assign sr_toggle_text = drawers.settings.shipping_and_returns_toggle_text -%}
		{%- assign sr_drawer_title = drawers.settings.shipping_and_returns_drawer_title | default: sr_page.title -%}

		{%- if sr_page != blank
			and sr_page.content != blank
			and sr_toggle_text != blank
		-%}
			{%- assign title = sr_drawer_title -%}
			{%- assign content = sr_page.content -%}
			{%- assign toggle_id = 'shippingAndReturnsDrawer-' | append: section.id -%}
			{%- assign class_container = 'product-shipping-and-returns-drawer' -%}
			{%- assign class_body = 'rte-product-drawer' -%}
			{%- assign full_width_mode = false -%}
			{%- include 'product-form-drawer' -%}
		{%- endif -%}

		{%- comment -%}
			Custom drawer 1
		{%- endcomment -%}
		{%- if drawers.settings.custom_drawer_title_1 != blank and drawers.settings.custom_drawer_text_1 != blank -%}
			{%- assign title = drawers.settings.custom_drawer_title_1 -%}
			{%- assign content = drawers.settings.custom_drawer_text_1 -%}
			{%- assign toggle_id = 'CustomDrawer-1-' | append: section.id -%}
			{%- assign class_container = '' -%}
			{%- assign class_body = 'rte-product-drawer' -%}
			{%- assign full_width_mode = false -%}
			{%- include 'product-form-drawer' -%}
		{%- endif -%}

		{%- comment -%}
			Custom drawer 2
		{%- endcomment -%}
		{%- if drawers.settings.custom_drawer_title_2 != blank and drawers.settings.custom_drawer_text_2 != blank -%}
			{%- assign title = drawers.settings.custom_drawer_title_2 -%}
			{%- assign content = drawers.settings.custom_drawer_text_2 -%}
			{%- assign toggle_id = 'CustomDrawer-2-' | append: section.id -%}
			{%- assign class_container = '' -%}
			{%- assign class_body = 'rte-product-drawer' -%}
			{%- assign full_width_mode = false -%}
			{%- include 'product-form-drawer' -%}
		{%- endif -%}

		{%- comment -%}
			Custom drawer 3
		{%- endcomment -%}
		{%- if drawers.settings.custom_drawer_title_3 != blank and drawers.settings.custom_drawer_text_3 != blank -%}
			{%- assign title = drawers.settings.custom_drawer_title_3 -%}
			{%- assign content = drawers.settings.custom_drawer_text_3 -%}
			{%- assign toggle_id = 'CustomDrawer-3-' | append: section.id -%}
			{%- assign class_container = '' -%}
			{%- assign class_body = 'rte-product-drawer' -%}
			{%- assign full_width_mode = false -%}
			{%- include 'product-form-drawer' -%}
		{%- endif -%}
	{%- endif -%}
{%- endfor -%}

{%- if options != nil -%}
	{%- assign size_guide_page = product.metafields.size_guide.page.value -%}

	{%- if size_guide_page != blank and size_guide_page.content != blank -%}
		{% assign toggle_id = 'productSizeGuideDrawer-' | append: section.id %}
		{% assign size_guide_page_content = size_guide_page.content | replace: '<img', '<img loading="lazy"'%}

		{% include 'product-form-drawer',
			title: options.settings.size_guide_title,
			content: size_guide_page_content,
			toggle_id: toggle_id,
			class_container: 'product-size-guide-drawer',
			tab_general_name: options.settings.size_guide_tab_general_name,
			tab_model_name: options.settings.size_guide_tab_model_name,
			full_width_mode: true
		%}
	{%- endif -%}
{%- endif -%}
