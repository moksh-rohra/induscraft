{{ 'work-showcase.css' | asset_url | stylesheet_tag }}

<section 
  id="work-showcase-{{ section.id }}" 
  class="work-showcase" 
  style="--bg-color: {{ section.settings.bg_color }}; --text-color: {{ section.settings.text_color }}"
>
    {%- for block in section.blocks -%}
       <div class="work-item" {{ block.shopify_attributes }}
         style="
           --overlay-color: {{ block.settings.overlay_color }};
           --overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
           --center-heading-color: {{ block.settings.center_heading_color }};
           --center-heading-size-d: {{ block.settings.center_heading_size_d }}px;
           --center-heading-size-m: {{ block.settings.center_heading_size_m }}px;
           --footer-heading-color: {{ block.settings.footer_heading_color }};
           --footer-heading-size-d: {{ block.settings.footer_heading_size_d }}px;
           --footer-heading-size-m: {{ block.settings.footer_heading_size_m }}px;
           --footer-desc-color: {{ block.settings.footer_desc_color }};
           --footer-desc-size-d: {{ block.settings.footer_desc_size_d }}px;
           --footer-desc-size-m: {{ block.settings.footer_desc_size_m }}px;
         "
       >
           <div class="work-item-img">
               {%- if block.settings.image != blank -%}
                   {{ block.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'work-item-image-asset' }}
               {%- else -%}
                   {{ 'lifestyle-1' | placeholder_svg_tag }}
               {%- endif -%}
               <div class="work-item-overlay"></div>
               <div class="work-item-footer">
                   <div class="work-item-footer__left">
                       {%- if block.settings.footer_subheading != blank -%}
                       <div class="work-item-footer__subheading-wrapper">
                           <div class="work-item-footer__icon"></div>
                           <span class="work-item-footer__subheading">{{ block.settings.footer_subheading }}</span>
                       </div>
                       {%- endif -%}
                       <h3 class="work-item-footer__heading" style="{% if block.settings.footer_heading_uppercase %}text-transform: uppercase;{% endif %}">{{ block.settings.footer_heading }}</h3>
                   </div>
                   <div class="work-item-footer__right">
                       <p class="work-item-footer__desc">{{ block.settings.footer_desc }}</p>
                        {%- if block.settings.gallery_image_1 != blank -%}
                            <a href="javascript:void(0)" class="work-item-gallery-link button-new button--{{ block.settings.gallery_link_style }} js-gallery-trigger" data-block-id="{{ block.id }}">
                                {{ block.settings.gallery_link_text | default: 'See our work' }}
                            </a>
                        {%- endif -%}
                   </div>
               </div>
           </div>
           <div class="work-item-name">
               <h1>{{ block.settings.heading }}</h1>
           </div>
       </div>
    {%- endfor -%}
</section>

<!-- Gallery Popup -->
<div class="work-gallery-overlay js-gallery-overlay" id="gallery-overlay-{{ section.id }}">
    <button type="button" class="work-gallery__close js-gallery-close" aria-label="Close gallery">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
    </button>
    
    <div class="work-gallery__container">
        <button type="button" class="work-gallery__nav work-gallery__nav--prev js-gallery-prev" aria-label="Previous image">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m15 18-6-6 6-6"/>
            </svg>
        </button>
        
        <div class="work-gallery__slider js-gallery-slider">
            {%- for block in section.blocks -%}
                <div class="work-gallery__slides" data-block-id="{{ block.id }}" style="display: none;">
                    {%- if block.settings.gallery_image_1 != blank -%}
                        <div class="work-gallery__slide" data-index="0" data-caption="{{ block.settings.gallery_caption_1 | escape }}">
                            {{ block.settings.gallery_image_1 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_2 != blank -%}
                        <div class="work-gallery__slide" data-index="1" data-caption="{{ block.settings.gallery_caption_2 | escape }}">
                            {{ block.settings.gallery_image_2 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_3 != blank -%}
                        <div class="work-gallery__slide" data-index="2" data-caption="{{ block.settings.gallery_caption_3 | escape }}">
                            {{ block.settings.gallery_image_3 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_4 != blank -%}
                        <div class="work-gallery__slide" data-index="3" data-caption="{{ block.settings.gallery_caption_4 | escape }}">
                            {{ block.settings.gallery_image_4 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_5 != blank -%}
                        <div class="work-gallery__slide" data-index="4" data-caption="{{ block.settings.gallery_caption_5 | escape }}">
                            {{ block.settings.gallery_image_5 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_6 != blank -%}
                        <div class="work-gallery__slide" data-index="5" data-caption="{{ block.settings.gallery_caption_6 | escape }}">
                            {{ block.settings.gallery_image_6 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_7 != blank -%}
                        <div class="work-gallery__slide" data-index="6" data-caption="{{ block.settings.gallery_caption_7 | escape }}">
                            {{ block.settings.gallery_image_7 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_8 != blank -%}
                        <div class="work-gallery__slide" data-index="7" data-caption="{{ block.settings.gallery_caption_8 | escape }}">
                            {{ block.settings.gallery_image_8 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_9 != blank -%}
                        <div class="work-gallery__slide" data-index="8" data-caption="{{ block.settings.gallery_caption_9 | escape }}">
                            {{ block.settings.gallery_image_9 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_10 != blank -%}
                        <div class="work-gallery__slide" data-index="9" data-caption="{{ block.settings.gallery_caption_10 | escape }}">
                            {{ block.settings.gallery_image_10 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_11 != blank -%}
                        <div class="work-gallery__slide" data-index="10" data-caption="{{ block.settings.gallery_caption_11 | escape }}">
                            {{ block.settings.gallery_image_11 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_12 != blank -%}
                        <div class="work-gallery__slide" data-index="11" data-caption="{{ block.settings.gallery_caption_12 | escape }}">
                            {{ block.settings.gallery_image_12 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_13 != blank -%}
                        <div class="work-gallery__slide" data-index="12" data-caption="{{ block.settings.gallery_caption_13 | escape }}">
                            {{ block.settings.gallery_image_13 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_14 != blank -%}
                        <div class="work-gallery__slide" data-index="13" data-caption="{{ block.settings.gallery_caption_14 | escape }}">
                            {{ block.settings.gallery_image_14 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                    {%- if block.settings.gallery_image_15 != blank -%}
                        <div class="work-gallery__slide" data-index="14" data-caption="{{ block.settings.gallery_caption_15 | escape }}">
                            {{ block.settings.gallery_image_15 | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'work-gallery__image' }}
                        </div>
                    {%- endif -%}
                </div>
            {%- endfor -%}
        </div>
        
        <button type="button" class="work-gallery__nav work-gallery__nav--next js-gallery-next" aria-label="Next image">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
            </svg>
        </button>
    </div>
    
    <div class="work-gallery__caption js-gallery-caption"></div>
    <div class="work-gallery__counter js-gallery-counter"></div>
</div>

<style>
    /* Gallery Link Button */
    .work-item-gallery-link.button-new {
        margin-top: 16px;
        padding: 12px 36px;
        font-size: var(--footer-desc-size-d, 14px);
    }
    
    @media (max-width: 900px) {
        .work-item-gallery-link.button-new {
            padding: 10px 28px;
            font-size: var(--footer-desc-size-m, 12px);
        }
    }
    
    /* Gallery Popup Overlay */
    .work-gallery-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.95);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
    }
    
    .work-gallery-overlay.is-open {
        opacity: 1;
        visibility: visible;
    }
    
    /* Close Button */
    .work-gallery__close {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 50px;
        height: 50px;
        border: none;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease, transform 0.2s ease;
        z-index: 10;
    }
    
    .work-gallery__close:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: rotate(90deg);
    }
    
    .work-gallery__close svg {
        stroke: #fff;
    }
    
    /* Gallery Container */
    .work-gallery__container {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        max-width: 1400px;
        height: calc(100vh - 100px);
        padding: 50px 100px;
    }
    
    /* Navigation Buttons */
    .work-gallery__nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 60px;
        height: 60px;
        border: none;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease;
        z-index: 10;
    }
    
    .work-gallery__nav:hover {
        background: rgba(255, 255, 255, 0.2);
    }
    
    .work-gallery__nav svg {
        stroke: #fff;
    }
    
    .work-gallery__nav--prev {
        left: 30px;
    }
    
    .work-gallery__nav--next {
        right: 30px;
    }
    
    /* Slider */
    .work-gallery__slider {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .work-gallery__slides {
        width: 100%;
        height: 100%;
        position: relative;
    }
    
    .work-gallery__slide {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: none;
        align-items: center;
        justify-content: center;
    }
    
    .work-gallery__slide.is-active {
        display: flex;
    }
    
    .work-gallery__image {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        border-radius: 8px;
    }
    
    /* Caption - at bottom on desktop */
    .work-gallery__caption {
        position: absolute;
        bottom: 25px;
        left: 50%;
        transform: translateX(-50%);
        color: #fff;
        font-size: 18px;
        font-weight: 500;
        text-align: center;
        max-width: 80%;
        letter-spacing: 1px;
    }
    
    .work-gallery__caption:empty {
        display: none;
    }
    
    /* Counter - at top on desktop */
    .work-gallery__counter {
        position: absolute;
        top: 25px;
        left: 50%;
        transform: translateX(-50%);
        color: rgba(255, 255, 255, 0.7);
        font-size: 14px;
        font-weight: 500;
        letter-spacing: 2px;
    }
    
    /* Mobile Responsive */
    @media (max-width: 768px) {
        .work-gallery__container {
            padding: 0 20px;
        }
        
        .work-gallery__nav {
            width: 45px;
            height: 45px;
        }
        
        .work-gallery__nav--prev {
            left: 10px;
        }
        
        .work-gallery__nav--next {
            right: 10px;
        }
        
        .work-gallery__nav svg {
            width: 24px;
            height: 24px;
        }
        
        .work-gallery__close {
            top: 15px;
            right: 15px;
            width: 40px;
            height: 40px;
        }
        
        .work-gallery__close svg {
            width: 20px;
            height: 20px;
        }
        
        /* Mobile: counter at bottom, caption above it */
        .work-gallery__counter {
            top: auto;
            bottom: 20px;
        }
        
        .work-gallery__caption {
            bottom: 45px;
        }
    }
</style>

<!-- Scripts -->
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<!-- Using the user provided CDN for SplitText -->
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/SplitText.min.js"></script> 

<script>

  (function() {
    function initWorkShowcase() {
      // Check GSAP availability
      if(typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

      gsap.registerPlugin(ScrollTrigger);
      if(typeof SplitText !== 'undefined') {
          gsap.registerPlugin(SplitText);
      } else {
          console.warn("SplitText not loaded properly.");
      }

      const sectionId = '{{ section.id }}';
      const container = document.getElementById(`work-showcase-${sectionId}`);
      if(!container) return;
      
      // Prevent double init
      if(container.dataset.init === "true") return;
      container.dataset.init = "true";

      const items = container.querySelectorAll(".work-item");

      items.forEach((item) => {
          const imgWrapper = item.querySelector(".work-item-img");
          const nameH1 = item.querySelector(".work-item-name h1");

          // Split Text Logic
          if(typeof SplitText !== 'undefined' && nameH1) {
              const split = new SplitText(nameH1, {
                  type: "chars",
                  charsClass: "char"
              });
              
              gsap.set(split.chars, { y: "125%" });
              
              split.chars.forEach((char, index) => {
                  ScrollTrigger.create({
                      trigger: item,
                      start: `top+=${index * 25 - 250} top`,
                      end: `top+=${index * 25 - 100} top`,
                      scrub: 1,
                      invalidateOnRefresh: true, // Recalculate on resize/refresh
                      animation: gsap.to(char, {
                          y: "0%",
                          ease: "none"
                      })
                  });
              });
          }

          // Check if mobile
          const isMobile = window.innerWidth <= 900;
          
          // Animation ranges based on screen size
          const entryEnd = isMobile ? "top 20%" : "top top";
          const exitStart = isMobile ? "bottom 80%" : "bottom bottom";
          const scrubValue = isMobile ? 1 : 0.5;

          // Image Clip Path Animation 1 (Enters)
          ScrollTrigger.create({
              trigger: item,
              start: "top bottom",
              end: entryEnd,
              scrub: scrubValue,
              invalidateOnRefresh: true,
              refreshPriority: -1,
              animation: gsap.fromTo(imgWrapper, 
                  { clipPath: "polygon(25% 25%, 75% 40%, 100% 100%, 0% 100%)" },
                  { clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)", ease: "none", immediateRender: false }
              )
          });

          // Image Clip Path Animation 2 (Exits)
          ScrollTrigger.create({
              trigger: item,
              start: exitStart,
              end: "bottom top",
              scrub: scrubValue,
              invalidateOnRefresh: true,
              animation: gsap.fromTo(imgWrapper,
                  { clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)" },
                  { clipPath: "polygon(0% 0%, 100% 0%, 75% 60%, 25% 75%)", ease: "none", immediateRender: false }
              )
          });
      });
      
      // Force refresh after a short delay to handle immediate rendering issues
      ScrollTrigger.refresh();
    }

    // Init on DOMContentLoaded
    if (document.readyState === 'loading') {
      document.addEventListener("DOMContentLoaded", initWorkShowcase);
    } else {
      initWorkShowcase();
    }

    // Refresh on full window load to account for images/styles
    window.addEventListener("load", () => {
      ScrollTrigger.refresh();
    });
    
    // Also listen for interactions/resize just in case
    window.addEventListener("resize", () => {
        ScrollTrigger.refresh();
    });

  })();
  
  // Gallery Popup Logic
  (function() {
    const sectionId = '{{ section.id }}';
    const overlay = document.getElementById(`gallery-overlay-${sectionId}`);
    if (!overlay) return;
    
    const closeBtn = overlay.querySelector('.js-gallery-close');
    const prevBtn = overlay.querySelector('.js-gallery-prev');
    const nextBtn = overlay.querySelector('.js-gallery-next');
    const counter = overlay.querySelector('.js-gallery-counter');
    const caption = overlay.querySelector('.js-gallery-caption');
    const triggers = document.querySelectorAll(`#work-showcase-${sectionId} .js-gallery-trigger`);
    
    let currentBlockId = null;
    let currentIndex = 0;
    let totalSlides = 0;
    
    function openGallery(blockId) {
        currentBlockId = blockId;
        currentIndex = 0;
        
        // Hide all block slides, show current
        const allSlides = overlay.querySelectorAll('.work-gallery__slides');
        allSlides.forEach(s => s.style.display = 'none');
        
        const currentSlides = overlay.querySelector(`.work-gallery__slides[data-block-id="${blockId}"]`);
        if (currentSlides) {
            currentSlides.style.display = 'block';
            const slides = currentSlides.querySelectorAll('.work-gallery__slide');
            totalSlides = slides.length;
            showSlide(0);
        }
        
        overlay.classList.add('is-open');
        document.body.style.overflow = 'hidden';
    }
    
    function closeGallery() {
        overlay.classList.remove('is-open');
        document.body.style.overflow = '';
    }
    
    function showSlide(index) {
        const currentSlides = overlay.querySelector(`.work-gallery__slides[data-block-id="${currentBlockId}"]`);
        if (!currentSlides) return;
        
        const slides = currentSlides.querySelectorAll('.work-gallery__slide');
        slides.forEach(s => s.classList.remove('is-active'));
        
        if (slides[index]) {
            slides[index].classList.add('is-active');
            currentIndex = index;
            counter.textContent = `${currentIndex + 1} / ${totalSlides}`;
            
            // Update caption
            const slideCaption = slides[index].dataset.caption || '';
            caption.textContent = slideCaption;
        }
    }
    
    function nextSlide() {
        const newIndex = (currentIndex + 1) % totalSlides;
        showSlide(newIndex);
    }
    
    function prevSlide() {
        const newIndex = (currentIndex - 1 + totalSlides) % totalSlides;
        showSlide(newIndex);
    }
    
    // Event Listeners
    triggers.forEach(trigger => {
        trigger.addEventListener('click', function(e) {
            e.preventDefault();
            const blockId = this.dataset.blockId;
            openGallery(blockId);
        });
    });
    
    if (closeBtn) closeBtn.addEventListener('click', closeGallery);
    if (prevBtn) prevBtn.addEventListener('click', prevSlide);
    if (nextBtn) nextBtn.addEventListener('click', nextSlide);
    
    overlay.addEventListener('click', function(e) {
        if (e.target === overlay) closeGallery();
    });
    
    document.addEventListener('keydown', function(e) {
        if (!overlay.classList.contains('is-open')) return;
        if (e.key === 'Escape') closeGallery();
        if (e.key === 'ArrowRight') nextSlide();
        if (e.key === 'ArrowLeft') prevSlide();
    });
  })();
</script>

{% schema %}
{
  "name": "Work Showcase",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "showcase_item",
      "name": "Work Item",
      "settings": [
        { "type": "header", "content": "Image" },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        { "type": "header", "content": "Overlay" },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Overlay Opacity",
          "default": 30
        },
        { "type": "header", "content": "Center Heading" },
        {
          "type": "text",
          "id": "heading",
          "label": "Center Heading",
          "default": "Carbon Edge"
        },
        {
          "type": "color",
          "id": "center_heading_color",
          "label": "Center Heading Color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "center_heading_size_d",
          "min": 40,
          "max": 200,
          "step": 4,
          "unit": "px",
          "label": "Center Heading Size (Desktop)",
          "default": 120
        },
        {
          "type": "range",
          "id": "center_heading_size_m",
          "min": 24,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Center Heading Size (Mobile)",
          "default": 48
        },
        { "type": "header", "content": "Bottom Left Subheading" },
        {
          "type": "text",
          "id": "footer_subheading",
          "label": "Bottom Left Subheading",
          "default": "CATEGORY"
        },
        { "type": "header", "content": "Bottom Left Heading" },
        {
          "type": "text",
          "id": "footer_heading",
          "label": "Bottom Left Heading",
          "default": "Project Type"
        },
        {
          "type": "color",
          "id": "footer_heading_color",
          "label": "Bottom Left Heading Color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "footer_heading_size_d",
          "min": 12,
          "max": 48,
          "step": 2,
          "unit": "px",
          "label": "Bottom Left Heading Size (Desktop)",
          "default": 20
        },
        {
