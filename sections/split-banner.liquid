            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "Padding Top (Desktop)",
            "default": 0
        },
        {
            "type": "range",
            "id": "padding_bottom_desktop",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
