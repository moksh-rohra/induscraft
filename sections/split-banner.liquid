{% style %}
    #shopify-section-{{ section.id }} {
        padding-top: {{ section.settings.padding_top_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    @media screen and (min-width: 768px) {
        #shopify-section-{{ section.id }} {
            padding-top: {{ section.settings.padding_top_desktop }}px;
            padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
        }
    }

    #shopify-section-{{ section.id }} .prod-split {
        width: 100%;
        margin: 0 auto;
        box-shadow: 0 4px 3px rgba(0, 0, 0, 0.08);
    }

    @media (min-width: 768px) {
        #shopify-section-{{ section.id }} .prod-split {
            width: {{ section.settings.section_width_desktop }}%;
        }
    }
    
    #shopify-section-{{ section.id }} .prod-split__container {
        display: flex;
        flex-direction: column;
        width: 100%;
        min-height: {{ section.settings.section_height_mobile }}px;
    }
    
    @media (min-width: 768px) {
        #shopify-section-{{ section.id }} .prod-split__container {
            flex-direction: row;
            height: {{ section.settings.section_height_desktop }}px;
            min-height: unset;
            overflow: hidden;
        }
        
        /* Layout Toggle Logic */
        #shopify-section-{{ section.id }} .prod-split__container.layout--image-right {
            flex-direction: row; /* Text (content) first, Image second */
        }
        
        #shopify-section-{{ section.id }} .prod-split__container.layout--image-left {
            flex-direction: row-reverse; /* Image (2nd div in DOM) becomes left, Text right */
        }
    }

    /* Content Column */
    #shopify-section-{{ section.id }} .prod-split__content {
        flex: 1;
        background-color: {{ section.settings.background_color }};
        color: {{ section.settings.text_color }};
        padding: 40px 20px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
    }

    @media (min-width: 768px) {
        #shopify-section-{{ section.id }} .prod-split__content {
            padding: {{ section.settings.content_padding }}px;
            width: {{ 100 | minus: section.settings.desktop_image_width }}%;
            flex: 0 0 {{ 100 | minus: section.settings.desktop_image_width }}%;
        }
    }

    #shopify-section-{{ section.id }} .prod-split__heading {
        margin: 0 0 10px 0;
        font-size: {{ section.settings.heading_font_size_mobile }}px;
        font-weight: 700;
        line-height: 1.1;
        color: inherit;
    }
    
    @media (min-width: 768px) {
        #shopify-section-{{ section.id }} .prod-split__heading {
            font-size: {{ section.settings.heading_font_size_desktop }}px;
        }
    }

    #shopify-section-{{ section.id }} .prod-split__price-box {
        margin-bottom: 16px;
        display: flex;
        align-items: baseline;
        gap: 12px;
    }

    #shopify-section-{{ section.id }} .prod-split__price {
        font-size: {{ section.settings.price_font_size }}px;
        font-weight: 700;
    }
    
    #shopify-section-{{ section.id }} .prod-split__compare-price {
        font-size: {{ section.settings.compare_price_font_size }}px;
        text-decoration: line-through;
        opacity: 0.6;
        font-weight: 400;
    }

    /* Circle Arrow Button */
    #shopify-section-{{ section.id }} .prod-split__btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background-color: #E8EBE6; /* Light greenish grey from image or default */
        color: #000;
        transition: transform 0.3s ease, background-color 0.3s ease;
        text-decoration: none;
        margin-top: 10px;
    }
    
    #shopify-section-{{ section.id }} .prod-split__btn:hover {
        transform: scale(1.1);
        background-color: #d8dcd5;
    }
    
    #shopify-section-{{ section.id }} .prod-split__btn svg {
        width: 20px;
        height: 20px;
        stroke: currentColor;
    }

    /* Image Column */
    #shopify-section-{{ section.id }} .prod-split__image-wrapper {
        flex: 1;
        position: relative;
        min-height: 300px;
        overflow: hidden;
    }

    @media (min-width: 768px) {
        #shopify-section-{{ section.id }} .prod-split__image-wrapper {
            width: {{ section.settings.desktop_image_width }}%;
            flex: 0 0 {{ section.settings.desktop_image_width }}%;
            min-height: 0; /* Force reset of mobile min-height */
        }
    }

    #shopify-section-{{ section.id }} .prod-split__image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

{% endstyle %}

<div class="prod-split">
    <!-- Note: Content is always first in DOM for mobile semantics (Text on top usually preferred, or modify if Image Top preferred) 
         If layout is 'image-left', we reverse the row on desktop.
    -->
    <div class="prod-split__container layout--{{ section.settings.layout_position }}">
        
        <div class="prod-split__content">
            {% if section.settings.heading != blank %}
                <h2 class="prod-split__heading">{{ section.settings.heading }}</h2>
            {% endif %}

            <div class="prod-split__price-box">
                {% if section.settings.price != blank %}
                    <span class="prod-split__price">{{ section.settings.price }}</span>
                {% endif %}
                
                {% if section.settings.compare_at_price != blank %}
                    <span class="prod-split__compare-price">{{ section.settings.compare_at_price }}</span>
                {% endif %}
            </div>

            {% if section.settings.link != blank %}
                <a href="{{ section.settings.link }}" class="prod-split__btn" aria-label="View Product">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
            {% endif %}
        </div>

        <div class="prod-split__image-wrapper">
            {% if section.settings.image != blank %}
                {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'prod-split__image', loading: 'lazy' }}
            {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'prod-split__image' }}
            {% endif %}
        </div>

    </div>
</div>

{% schema %}
{
    "name": "Split Banner",
    "settings": [
        {
            "type": "header",
            "content": "Layout"
        },
        {
            "type": "header",
