{{ 'section-custom-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .section-{{ section.id }}-padding .ccf-heading {
    font-size: {{ section.settings.heading_size_mobile }}px;
    color: {{ section.settings.heading_color }};
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding .ccf-heading {
      font-size: {{ section.settings.heading_size }}px;
    }
  }

  .section-{{ section.id }}-padding .ccf-description {
    color: {{ section.settings.text_color }};
  }

  .section-{{ section.id }}-padding .ccf-info-title {
    color: {{ section.settings.heading_color }};
  }

  .section-{{ section.id }}-padding .ccf-info-text,
  .section-{{ section.id }}-padding .ccf-info-highlight {
    color: {{ section.settings.text_color }};
  }

  .section-{{ section.id }}-padding .ccf-info-highlight {
    color: {{ section.settings.link_color }};
  }

  .section-{{ section.id }}-padding .ccf-form-card {
    background-color: {{ section.settings.form_bg_color }};
    border-radius: {{ section.settings.form_border_radius }}px;
  }

  .section-{{ section.id }}-padding .ccf-form-heading {
    color: {{ section.settings.form_heading_color }};
  }

  .section-{{ section.id }}-padding .ccf-form-label {
    color: {{ section.settings.form_label_color }};
  }

  .section-{{ section.id }}-padding .ccf-form-input {
    background-color: {{ section.settings.input_bg_color }};
    border-color: {{ section.settings.input_border_color }};
    color: {{ section.settings.input_text_color }};
  }

  .section-{{ section.id }}-padding .ccf-form-textarea {
    background-color: transparent;
    border-color: {{ section.settings.input_border_color }};
    color: {{ section.settings.input_text_color }};
  }

  .section-{{ section.id }}-padding .ccf-form-input::placeholder,
  .section-{{ section.id }}-padding .ccf-form-textarea::placeholder {
    color: {{ section.settings.input_placeholder_color }};
  }

  .section-{{ section.id }}-padding .ccf-form-btn {
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    border-radius: {{ section.settings.button_border_radius }}px;
  }

  .section-{{ section.id }}-padding .ccf-form-btn:hover {
    background-color: {{ section.settings.button_hover_bg_color }};
    color: {{ section.settings.button_hover_text_color }};
  }
{%- endstyle -%}

<div class="custom-contact-form-section section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="ccf-container">
      <!-- Left Column: Content & Info -->
      <div class="ccf-left-column">
        {%- if section.settings.heading != blank -%}
          <h2 class="ccf-heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="ccf-description">{{ section.settings.description | escape }}</p>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="ccf-info-grid">
            {%- for block in section.blocks -%}
              {%- if block.type == 'ccf_contact_info' -%}
                <div class="ccf-info-block" {{ block.shopify_attributes }}>
                  <h4 class="ccf-info-title">{{ block.settings.title | escape }}</h4>
                  {%- if block.settings.text != blank -%}
                    <p class="ccf-info-text">{{ block.settings.text | escape }}</p>
                  {%- endif -%}
                  {%- if block.settings.highlight != blank -%}
                    {%- if block.settings.highlight_link != blank -%}
                      <a href="{{ block.settings.highlight_link }}" class="ccf-info-highlight">{{ block.settings.highlight | escape }}</a>
                    {%- else -%}
                      <span class="ccf-info-highlight">{{ block.settings.highlight | escape }}</span>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Right Column: Form Card -->
      <div class="ccf-right-column">
        <div class="ccf-form-card">
          {%- if section.settings.form_heading != blank -%}
            <h3 class="ccf-form-heading">{{ section.settings.form_heading | escape }}</h3>
          {%- endif -%}

          {%- form 'contact', class: 'ccf-form' -%}
            {%- if form.posted_successfully? -%}
              <div class="ccf-form-success">
                <p>{{ section.settings.success_message | default: 'Thank you for your message. We will get back to you shortly.' }}</p>
              </div>
            {%- endif -%}

            {%- if form.errors -%}
              <div class="ccf-form-errors">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="ccf-form-row ccf-form-row--double">
              <div class="ccf-form-group">
                <label for="ccf-first-name-{{ section.id }}" class="ccf-form-label">
                  {{ section.settings.first_name_label | default: 'First name' }} <span class="ccf-required">*</span>
                </label>
                <input 
                  type="text" 
                  id="ccf-first-name-{{ section.id }}" 
                  name="contact[first_name]" 
                  class="ccf-form-input"
                  placeholder="{{ section.settings.first_name_placeholder | default: 'Jane' }}"
                  required
                >
              </div>
              <div class="ccf-form-group">
                <label for="ccf-last-name-{{ section.id }}" class="ccf-form-label">
                  {{ section.settings.last_name_label | default: 'Last name' }} <span class="ccf-required">*</span>
                </label>
                <input 
                  type="text" 
                  id="ccf-last-name-{{ section.id }}" 
                  name="contact[last_name]" 
                  class="ccf-form-input"
                  placeholder="{{ section.settings.last_name_placeholder | default: 'Smith' }}"
                  required
                >
              </div>
            </div>

            <div class="ccf-form-row">
              <div class="ccf-form-group">
                <label for="ccf-email-{{ section.id }}" class="ccf-form-label">
                  {{ section.settings.email_label | default: 'Email' }} <span class="ccf-required">*</span>
                </label>
                <input 
                  type="email" 
                  id="ccf-email-{{ section.id }}" 
                  name="contact[email]" 
                  class="ccf-form-input"
                  placeholder="{{ section.settings.email_placeholder | default: 'jane@email.com' }}"
                  required
                >
              </div>
            </div>

            <div class="ccf-form-row">
              <div class="ccf-form-group">
                <label for="ccf-message-{{ section.id }}" class="ccf-form-label">
                  {{ section.settings.message_label | default: 'Message' }} <span class="ccf-required">*</span>
                </label>
                <textarea 
                  id="ccf-message-{{ section.id }}" 
                  name="contact[body]" 
                  class="ccf-form-textarea"
                  rows="4"
                  placeholder="{{ section.settings.message_placeholder | default: 'Leave us a message...' }}"
                  required
                ></textarea>
              </div>
            </div>

            {%- if section.settings.show_privacy_checkbox -%}
              <div class="ccf-form-row">
                <div class="ccf-form-checkbox-group">
                  <input 
                    type="checkbox" 
                    id="ccf-privacy-{{ section.id }}" 
                    name="contact[privacy]" 
                    class="ccf-form-checkbox"
                    required
                  >
                  <label for="ccf-privacy-{{ section.id }}" class="ccf-form-checkbox-label">
                    {%- if section.settings.privacy_link != blank -%}
                      {{ section.settings.privacy_text_before | default: 'I agree the' }} <a href="{{ section.settings.privacy_link }}" target="_blank">{{ section.settings.privacy_link_text | default: 'Privacy Policy' }}</a>.
                    {%- else -%}
                      {{ section.settings.privacy_text | default: 'I agree the Privacy Policy.' }}
                    {%- endif -%}
                  </label>
                </div>
              </div>
            {%- endif -%}

            <div class="ccf-form-row ccf-form-row--submit">
              <button type="submit" class="ccf-form-btn">
                {{ section.settings.button_text | default: 'Send' }}
              </button>
            </div>
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</div>

