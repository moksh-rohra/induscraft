{{ 'section-video-reviews.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  
  .section-{{ section.id }}-padding .video-reviews-title {
    font-size: {{ section.settings.heading_size_mobile }}px;
    color: {{ section.settings.heading_color }};
  }
  
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding .video-reviews-title {
      font-size: {{ section.settings.heading_size }}px;
    }
  }
  
  .section-{{ section.id }}-padding .video-reviews-header {
    text-align: {{ section.settings.heading_alignment }};
  }

  .section-{{ section.id }}-padding .vr-card {
    width: {{ section.settings.card_width_mobile }}px;
    height: {{ section.settings.card_height_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding .vr-card {
      width: {{ section.settings.card_width }}px;
      height: {{ section.settings.card_height }}px;
    }
  }

  .section-{{ section.id }}-padding .vr-play-pause-btn {
    background: {{ section.settings.play_button_color }};
  }
  .section-{{ section.id }}-padding .vr-play-pause-btn:hover {
    background: {{ section.settings.play_button_color }};
    filter: brightness(1.1);
  }
  .section-{{ section.id }}-padding .vr-play-pause-btn svg {
    color: {% if section.settings.play_button_color == '#181210' or section.settings.play_button_color == '#181210' %}#1a1a1a{% else %}#181210{% endif %};
  }
{%- endstyle -%}

<div class="video-reviews-section section-{{ section.id }}-padding" data-section-id="{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <div class="video-reviews-header">
      <h2 class="video-reviews-title">{{ section.settings.heading | escape }}</h2>
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    {%- capture all_content -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'vr_video_card' -%}
          <div class="vr-card" {{ block.shopify_attributes }} data-block-id="{{ block.id }}">
            <div class="vr-video-wrapper">
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: 
                  autoplay: false, 
                  loop: true, 
                  muted: true, 
                  playsinline: true, 
                  class: 'vr-video',
                  preload: 'none',
                  image_size: '800x'
                }}
              {%- elsif block.settings.video_url != blank -%}
                {%- if block.settings.video_url.type == 'youtube' -%}
                  <iframe 
                    class="vr-video vr-video-iframe"
                    src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?enablejsapi=1&mute=1&loop=1&playlist={{ block.settings.video_url.id }}&playsinline=1"
                    frameborder="0"
                    allow="autoplay; encrypted-media"
                    allowfullscreen
                  ></iframe>
                {%- elsif block.settings.video_url.type == 'vimeo' -%}
                  <iframe
                    class="vr-video vr-video-iframe"
                    src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?muted=1&loop=1&autopause=0"
                    frameborder="0"
                    allow="autoplay; encrypted-media"
                    allowfullscreen
                  ></iframe>
                {%- endif -%}
              {%- else -%}
                <div class="vr-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                  <span>No video</span>
                </div>
              {%- endif -%}

              <!-- Play/Pause Button (Center) -->
              <button class="vr-play-pause-btn" aria-label="Play/Pause video">
                <svg class="vr-icon-play" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M8 5v14l11-7z"/>
                </svg>
                <svg class="vr-icon-pause" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
                </svg>
              </button>

              <!-- Mute/Unmute Button (Bottom Right) -->
              <button class="vr-mute-btn" aria-label="Mute/Unmute video">
                <svg class="vr-icon-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
                </svg>
                <svg class="vr-icon-unmuted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
                </svg>
              </button>
            </div>

            {%- if block.settings.reviewer_name != blank -%}
              <div class="vr-reviewer-info">
                <span class="vr-reviewer-name">{{ block.settings.reviewer_name | escape }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- endcapture -%}

    <div class="vr-marquee-wrapper" data-speed="{{ section.settings.scroll_speed }}" data-pause-on-hover="{{ section.settings.pause_on_hover }}">
      <div class="vr-marquee-content" style="animation-duration: {{ section.settings.scroll_speed }}s;">
        {{ all_content }}
        {{ all_content }}
        {{ all_content }}
        {{ all_content }}
      </div>
    </div>
  {%- endif -%}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const section = document.querySelector('.video-reviews-section[data-section-id="{{ section.id }}"]');
  if (!section) return;

  const marqueeWrapper = section.querySelector('.vr-marquee-wrapper');
  const marqueeContent = marqueeWrapper.querySelector('.vr-marquee-content');
  
  if (!marqueeWrapper || !marqueeContent) return;

  // Disable CSS animation - we'll handle it with JS
  marqueeContent.style.animation = 'none';
  
  let isDragging = false;
  let startX = 0;
  let currentX = 0;
  let velocity = 0;
  let lastX = 0;
  let lastTime = 0;
  let animationId = null;
  let isHovered = false;
  let scrollDirection = -1; // -1 = left (default), 1 = right
  let targetSpeed = 1;
  let currentSpeed = 1;
  let activeVideo = null; // Track currently playing video/card
  
  const baseSpeed = 1.5; // pixels per frame at 60fps
  const speed = parseFloat(marqueeWrapper.dataset.speed) || 40;
  const scrollSpeed = (100 / speed) * baseSpeed; // Faster for lower speed values
  
  // Get total width of one set of content
  function getContentWidth() {
    return marqueeContent.scrollWidth / 4; // We have 4 copies
  }
  
  // Main animation loop
  function animate() {
    if (!isDragging) {
      // Smooth speed transitions for hover
      if (currentSpeed !== targetSpeed) {
        const diff = targetSpeed - currentSpeed;
        currentSpeed += diff * 0.05;
        if (Math.abs(diff) < 0.01) {
          currentSpeed = targetSpeed;
        }
      }
      
      // Determine target auto-scroll velocity
      const targetAutoVelocity = scrollDirection * scrollSpeed * currentSpeed;
      
      // Smoothly blend velocity toward target auto-scroll speed
      if (Math.abs(velocity) > Math.abs(targetAutoVelocity) * 0.5) {
        // Still have significant momentum - apply it with friction
        currentX += velocity;
        velocity *= 0.96; // Slightly less friction for smoother feel
        
        // Update scroll direction based on velocity direction
        scrollDirection = velocity > 0 ? 1 : -1;
      } else {
        // Blend velocity toward auto-scroll speed
        velocity += (targetAutoVelocity - velocity) * 0.08;
        currentX += velocity;
      }
      
      // Wrap around seamlessly
      const contentWidth = getContentWidth();
      if (currentX <= -contentWidth) {
        currentX += contentWidth;
      } else if (currentX > 0) {
        currentX -= contentWidth;
      }
      
      marqueeContent.style.transform = `translateX(${currentX}px)`;
    }
    
    animationId = requestAnimationFrame(animate);
  }
  
  // Start animation
  animate();
  
  // Mouse Events for Drag
  marqueeWrapper.addEventListener('mousedown', (e) => {
    if (e.target.closest('.vr-play-pause-btn') || e.target.closest('.vr-mute-btn')) return;
    
    // Pause any playing video when starting to drag
    pauseAllVideos();
    
    isDragging = true;
    marqueeWrapper.classList.add('dragging');
    startX = e.pageX - currentX;
    lastX = e.pageX;
    lastTime = Date.now();
    velocity = 0;
  });

  document.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    e.preventDefault();
    
    const x = e.pageX;
    const now = Date.now();
    const dt = now - lastTime;
    
    if (dt > 0) {
      velocity = (x - lastX) * 0.3; // Scale velocity for smoother feel
    }
    
    lastX = x;
    lastTime = now;
    
    currentX = x - startX;
    
    // Wrap around
    const contentWidth = getContentWidth();
    if (currentX <= -contentWidth) {
      currentX += contentWidth;
      startX -= contentWidth;
    } else if (currentX > 0) {
      currentX -= contentWidth;
      startX += contentWidth;
    }
    
    marqueeContent.style.transform = `translateX(${currentX}px)`;
  });

  document.addEventListener('mouseup', () => {
    if (!isDragging) return;
    isDragging = false;
    marqueeWrapper.classList.remove('dragging');
    // Velocity is already set from mousemove, momentum will be applied in animate()
  });

  // Touch Events for Drag
  marqueeWrapper.addEventListener('touchstart', (e) => {
    if (e.target.closest('.vr-play-pause-btn') || e.target.closest('.vr-mute-btn')) return;
    
    // Pause any playing video when starting to drag
    pauseAllVideos();
    
    isDragging = true;
    marqueeWrapper.classList.add('dragging');
    startX = e.touches[0].pageX - currentX;
    lastX = e.touches[0].pageX;
    lastTime = Date.now();
    velocity = 0;
  }, { passive: true });

  marqueeWrapper.addEventListener('touchmove', (e) => {
    if (!isDragging) return;
    
    const x = e.touches[0].pageX;
    const now = Date.now();
    const dt = now - lastTime;
    
    if (dt > 0) {
      velocity = (x - lastX) * 0.3;
    }
    
    lastX = x;
    lastTime = now;
    
    currentX = x - startX;
    
    // Wrap around
    const contentWidth = getContentWidth();
    if (currentX <= -contentWidth) {
      currentX += contentWidth;
      startX -= contentWidth;
    } else if (currentX > 0) {
      currentX -= contentWidth;
      startX += contentWidth;
    }
    
    marqueeContent.style.transform = `translateX(${currentX}px)`;
  }, { passive: true });

  marqueeWrapper.addEventListener('touchend', () => {
    if (!isDragging) return;
    isDragging = false;
    marqueeWrapper.classList.remove('dragging');
  });

  // Hover to slow down/pause
  marqueeWrapper.addEventListener('mouseenter', () => {
    if (!isDragging && marqueeWrapper.dataset.pauseOnHover === 'true') {
      isHovered = true;
      targetSpeed = 0;
    }
  });

  marqueeWrapper.addEventListener('mouseleave', () => {
    isHovered = false;
    // Only resume if no video is playing
    if (!activeVideo) {
      targetSpeed = 1;
    }
  });

  // Function to pause all videos
  function pauseAllVideos() {
    section.querySelectorAll('.vr-card').forEach(card => {
      const video = card.querySelector('video.vr-video');
      const iframe = card.querySelector('.vr-video-iframe');
      
      if (video && !video.paused) {
        video.pause();
        card.classList.remove('is-playing');
      } else if (iframe && card.classList.contains('is-playing')) {
        const src = iframe.src;
        if (src.includes('youtube')) {
          iframe.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
        } else if (src.includes('vimeo')) {
          iframe.contentWindow.postMessage('{"method":"pause"}', '*');
        }
        card.classList.remove('is-playing');
      }
    });
    activeVideo = null;
    targetSpeed = 1;
  }

  // Video Controls
  const videoCards = section.querySelectorAll('.vr-card');
  
  videoCards.forEach(card => {
    const video = card.querySelector('video.vr-video');
    const iframe = card.querySelector('.vr-video-iframe');
    const playPauseBtn = card.querySelector('.vr-play-pause-btn');
    const muteBtn = card.querySelector('.vr-mute-btn');
    
    let isPlaying = false;
    let isMuted = true;

    if (playPauseBtn) {
      playPauseBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        
        if (video) {
          if (video.paused) {
            // Pause any other playing videos first
            pauseAllVideos();
            video.play();
            isPlaying = true;
            card.classList.add('is-playing');
            activeVideo = card;
            targetSpeed = 0; // Stop marquee
          } else {
            video.pause();
            isPlaying = false;
            card.classList.remove('is-playing');
            activeVideo = null;
            targetSpeed = 1; // Resume marquee
          }
        } else if (iframe) {
          const src = iframe.src;
          if (src.includes('youtube')) {
            if (isPlaying) {
              iframe.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
              isPlaying = false;
              card.classList.remove('is-playing');
              activeVideo = null;
              targetSpeed = 1; // Resume marquee
            } else {
              pauseAllVideos();
              iframe.contentWindow.postMessage('{"event":"command","func":"playVideo","args":""}', '*');
              isPlaying = true;
              card.classList.add('is-playing');
              activeVideo = card;
              targetSpeed = 0; // Stop marquee
            }
          } else if (src.includes('vimeo')) {
            if (isPlaying) {
              iframe.contentWindow.postMessage('{"method":"pause"}', '*');
              isPlaying = false;
              card.classList.remove('is-playing');
              activeVideo = null;
              targetSpeed = 1; // Resume marquee
            } else {
              pauseAllVideos();
              iframe.contentWindow.postMessage('{"method":"play"}', '*');
              isPlaying = true;
              card.classList.add('is-playing');
              activeVideo = card;
              targetSpeed = 0; // Stop marquee
            }
          }
        }
      });
    }

    if (muteBtn) {
      muteBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        
        if (video) {
          video.muted = !video.muted;
          isMuted = video.muted;
          card.classList.toggle('is-muted', isMuted);
        } else if (iframe) {
          const src = iframe.src;
          if (src.includes('youtube')) {
            if (isMuted) {
              iframe.contentWindow.postMessage('{"event":"command","func":"unMute","args":""}', '*');
              isMuted = false;
            } else {
              iframe.contentWindow.postMessage('{"event":"command","func":"mute","args":""}', '*');
              isMuted = true;
            }
            card.classList.toggle('is-muted', isMuted);
          } else if (src.includes('vimeo')) {
            if (isMuted) {
              iframe.contentWindow.postMessage('{"method":"setVolume","value":1}', '*');
              isMuted = false;
            } else {
              iframe.contentWindow.postMessage('{"method":"setVolume","value":0}', '*');
              isMuted = true;
            }
            card.classList.toggle('is-muted', isMuted);
          }
        }
      });
    }

    // Set initial muted state
    card.classList.add('is-muted');
  });
});
</script>

{% schema %}
{
  "name": "Video Reviews Marquee",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Video Reviews"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Heading Size (Desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading Size (Mobile)",
      "default": 24
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#202124"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Card Settings"
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 200,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Card Width (Desktop)",
      "default": 300
    },
    {
      "type": "range",
      "id": "card_height",
      "min": 300,
      "max": 700,
      "step": 10,
      "unit": "px",
      "label": "Card Height (Desktop)",
      "default": 450
    },
    {
      "type": "range",
      "id": "card_width_mobile",
      "min": 150,
      "max": 350,
      "step": 10,
      "unit": "px",
      "label": "Card Width (Mobile)",
      "default": 220
    },
    {
      "type": "range",
      "id": "card_height_mobile",
      "min": 250,
      "max": 550,
      "step": 10,
      "unit": "px",
      "label": "Card Height (Mobile)",
      "default": 350
    },
    {
      "type": "header",
      "content": "Marquee Settings"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "s",
      "label": "Scroll Speed (Seconds)",
      "default": 40,
      "info": "Lower is faster."
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on Hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "play_button_color",
      "label": "Play Button Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "vr_video_card",
      "name": "Video Card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Upload a video file (MP4, WebM, etc.)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Or Video URL",
          "accept": ["youtube", "vimeo"],
          "info": "If video file is not provided, use YouTube or Vimeo URL."
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "Happy Customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Reviews Marquee",
      "blocks": [
        {
          "type": "vr_video_card"
        },
        {
          "type": "vr_video_card"
        },
        {
          "type": "vr_video_card"
        }
      ]
    }
  ]
}
{% endschema %}
