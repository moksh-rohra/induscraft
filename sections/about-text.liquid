{%- comment -%}
------------------------------------------------------------------------------
	Section: About Text
	 - A split layout section with a small label on the left and large text content on the right.
	 - Supports theme-styled buttons.
------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign small_heading = section.settings.small_heading -%}
{%- assign main_heading = section.settings.main_heading -%}
{%- assign text_color = section.settings.text_color -%}
{%- assign background_color = section.settings.background_color -%}
{%- assign button_label = section.settings.button_label -%}
{%- assign button_link = section.settings.button_link -%}
{%- assign button_style = section.settings.button_style -%}

{%- assign full_width = section.settings.full_width -%}
{%- assign content_max_width = section.settings.content_max_width -%}

<style>
	#shopify-section-{{ section.id }} {
		background-color: {{ background_color }};
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	@media screen and (min-width: 768px) {
		#shopify-section-{{ section.id }} {
			padding-top: {{ section.settings.padding_top_desktop }}px;
			padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
		}
	}

	.about-text__container {
		{%- if full_width -%}
			max-width: 100%;
		{%- else -%}
			max-width: var(--global-container-width, 1440px);
		{%- endif -%}
		margin: 0 auto;
		padding: 0 {{ section.settings.padding_horizontal_mobile }}px;
		color: {{ text_color }};
	}
	
	@media screen and (min-width: 768px) {
		.about-text__container {
			padding: 0 {{ section.settings.padding_horizontal_desktop }}px;
			display: grid;
			grid-template-columns: 3fr 7fr;
			gap: 40px;
			align-items: start;
		}
	}

	/* Left Column: Small Heading */
	.about-text__label {
		display: flex;
		align-items: center;
		font-size: {{ section.settings.label_size_mobile }}px !important;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		font-weight: 500;
		margin-bottom: 30px;
		line-height: 1;
	}

	.about-text__label-icon {
		display: inline-block;
		width: 10px;
		height: 10px;
		background-color: currentColor;
		margin-right: 12px;
	}

	@media screen and (min-width: 768px) {
		.about-text__label {
			font-size: {{ section.settings.label_size_desktop }}px !important;
			margin-bottom: 0;
			position: sticky;
			top: 40px;
		}
	}

	/* Right Column: Main Content */
	.about-text__content {
		display: flex;
		flex-direction: column;
		gap: 32px;
		max-width: {{ content_max_width }}px;
		width: 100%;
		margin: 0 auto; /* Fixes centering issue */
	}

	.about-text__heading {
		font-family: var(--heading-font-family);
		font-size: {{ section.settings.heading_size_mobile }}px !important;
		line-height: 1.3;
		font-weight: 400;
		margin: 0;
	}

	@media screen and (min-width: 768px) {
		.about-text__heading {
			font-size: {{ section.settings.heading_size_desktop }}px !important;
			line-height: 1.25;
		}
	}

	.about-text__actions {
		display: flex;
		flex-wrap: wrap;
	}

	.about-text__border {
		width: 100%;
		margin-bottom: {{ section.settings.border_spacing }}px;
		border-top-style: solid;
		border-top-width: {{ section.settings.border_width }}px;
		border-top-color: {{ section.settings.border_color }};
	}

	@media screen and (min-width: 768px) {
		.about-text__border {
			grid-column: 1 / -1;
		}
	}
</style>

<div class="about-text__container">
	{%- if section.settings.show_top_border -%}
		<div class="about-text__border left-animate"></div>
	{%- endif -%}

	<div class="about-text__label left-animate">
		{%- if small_heading != blank -%}
			<span class="about-text__label-icon"></span>
			{{- small_heading -}}
		{%- endif -%}
	</div>

	<div class="about-text__content">
		{%- if main_heading != blank -%}
			<h2 class="about-text__heading right-animate">
				{{- main_heading -}}
			</h2>
		{%- endif -%}

		{%- if button_label != blank and button_link != blank -%}
			<div class="about-text__actions right-animate">
				{%- if button_style == 'circle' -%}
					<a href="{{ button_link }}" class="button-circle" aria-label="{{ button_label }}">
						<span class="button__text">{{ button_label }}</span>
						<span class="button-new__icon-container">
							<span class="button-new__icon-wrapper">
								{% render 'icons-new', icon: 'arrow-right' %}
							</span>
						</span>
					</a>
				{%- else -%}
					<a href="{{ button_link }}" class="button-new button--{{ button_style }}">
						{{ button_label }}
					</a>
				{%- endif -%}
			</div>
		{%- endif -%}
	</div>
</div>

{% schema %}
{
	"name": "About Text",
	"settings": [
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "checkbox",
			"id": "full_width",
			"label": "Full Width",
			"default": false
		},
		{
			"type": "range",
			"id": "content_max_width",
			"min": 400,
			"max": 1200,
			"step": 20,
			"unit": "px",
			"label": "Content Max Width",
			"default": 800
		},
		{
			"type": "header",
			"content": "Typography"
		},
		{
			"type": "paragraph",
			"content": "Small Label"
		},
		{
			"type": "range",
			"id": "label_size_mobile",
			"min": 10,
			"max": 30,
			"step": 1,
			"unit": "px",
			"label": "Mobile Font Size",
			"default": 13
		},
		{
			"type": "range",
			"id": "label_size_desktop",
			"min": 10,
			"max": 30,
			"step": 1,
			"unit": "px",
			"label": "Desktop Font Size",
			"default": 13
		},
		{
			"type": "paragraph",
			"content": "Main Heading"
		},
		{
			"type": "range",
			"id": "heading_size_mobile",
			"min": 20,
			"max": 60,
			"step": 1,
			"unit": "px",
			"label": "Mobile Font Size",
			"default": 28
		},
		{
			"type": "range",
			"id": "heading_size_desktop",
			"min": 20,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Desktop Font Size",
			"default": 42
		},
		{
			"type": "header",
			"content": "Content"
		},
		{
			"type": "text",
			"id": "small_heading",
			"label": "Small Label",
			"default": "ABOUT STUDIO"
		},
		{
			"type": "textarea",
			"id": "main_heading",
			"label": "Main Heading",
			"default": "We design interiors that blend style, comfort, and functionality. With a passion for detail and a focus on timeless elegance, we transform spaces into beautiful, inspiring environments."
		},
		{
			"type": "header",
			"content": "Button"
		},
		{
			"type": "text",
			"id": "button_label",
			"label": "Button Label",
			"default": "More About Us"
		},
		{
			"type": "url",
			"id": "button_link",
			"label": "Button Link"
		},
		{
			"type": "select",
			"id": "button_style",
			"label": "Button Style",
			"options": [
				{ "value": "primary", "label": "Primary" },
				{ "value": "secondary", "label": "Secondary" },
				{ "value": "circle", "label": "Circle" }
			],
			"default": "primary"
		},
		{
			"type": "header",
			"content": "Colors"
		},
		{
			"type": "color",
			"id": "text_color",
			"label": "Text Color",
			"default": "#000000"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background Color",
			"default": "#FFFFFF"
		},
		{
			"type": "header",
			"content": "Spacing"
		},
		{
			"type": "range",
			"id": "padding_top_desktop",
			"min": 0,
			"max": 200,
			"step": 4,
			"unit": "px",
			"label": "Desktop Top Padding",
			"default": 100
		},
		{
			"type": "range",
			"id": "padding_bottom_desktop",
			"min": 0,
			"max": 200,
			"step": 4,
			"unit": "px",
			"label": "Desktop Bottom Padding",
			"default": 100
		},
		{
			"type": "header",
			"content": "Borders"
		},
		{
			"type": "checkbox",
			"id": "show_top_border",
			"label": "Show Top Border",
			"default": false
		},
		{
			"type": "color",
			"id": "border_color",
			"label": "Border Color",
			"default": "#000000"
		},
		{
			"type": "range",
			"id": "border_width",
			"min": 1,
			"max": 10,
			"step": 1,
			"unit": "px",
			"label": "Border Thickness",
			"default": 1
		},
		{
			"type": "range",
			"id": "border_spacing",
			"min": 0,
			"max": 100,
			"step": 4,
			"unit": "px",
			"label": "Space Below Border",
			"default": 40
		},
		{
			"type": "header",
			"content": "Horizontal Spacing"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 4,
			"unit": "px",
			"label": "Mobile Top Padding",
			"default": 60
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 4,
			"unit": "px",
			"label": "Mobile Bottom Padding",
			"default": 60
		},
		{
			"type": "range",
			"id": "padding_horizontal_desktop",
			"min": 0,
			"max": 200,
			"step": 4,
			"unit": "px",
			"label": "Desktop Horizontal Padding",
			"default": 60
		},
		{
			"type": "range",
			"id": "padding_horizontal_mobile",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Mobile Horizontal Padding",
			"default": 20
		}
	],
	"presets": [
		{
			"name": "About Text"
		}
	]
}
{% endschema %}
