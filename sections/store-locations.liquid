{%- comment -%}
------------------------------------------------------------------------------
  Section: Store Locations
  A section to display physical store locations with icons and labels
------------------------------------------------------------------------------
{%- endcomment -%}

{%- style -%}
    /* Section Padding */
    #shopify-section-{{ section.id }} {
        padding-top: {{ section.settings.padding_top_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
        background-color: {{ section.settings.background_color }};
    }

    @media screen and (min-width: 768px) {
        #shopify-section-{{ section.id }} {
            padding-top: {{ section.settings.padding_top_desktop }}px;
            padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
        }
    }

    /* Main Container */
    #shopify-section-{{ section.id }} .store-locations {
        width: 100%;
        max-width: {{ section.settings.max_width }}px;
        margin: 0 auto;
        padding: 0 20px;
    }

    @media (min-width: 768px) {
        #shopify-section-{{ section.id }} .store-locations {
            padding: 0 60px;
        }
    }

    /* Heading */
    #shopify-section-{{ section.id }} .store-locations__heading {
        margin: 0 0 24px 0;
        font-size: {{ section.settings.heading_font_size_mobile }}px;
        line-height: 1.2;
        color: {{ section.settings.heading_color }};
        text-align: {{ section.settings.heading_alignment }};
    }

    @media (min-width: 768px) {
        #shopify-section-{{ section.id }} .store-locations__heading {
            font-size: {{ section.settings.heading_font_size_desktop }}px;
            margin-bottom: 32px;
        }
    }

    /* Bordered Container */
    #shopify-section-{{ section.id }} .store-locations__container {
        border: 1px solid {{ section.settings.border_color }};
        border-radius: {{ section.settings.border_radius }}px;
        padding: 24px 16px;
    }

    @media (min-width: 768px) {
        #shopify-section-{{ section.id }} .store-locations__container {
            padding: 32px 40px;
        }
    }

    /* Grid Layout */
    #shopify-section-{{ section.id }} .store-locations__grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px 16px;
    }

    @media (min-width: 480px) {
        #shopify-section-{{ section.id }} .store-locations__grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @media (min-width: 768px) {
        #shopify-section-{{ section.id }} .store-locations__grid {
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 32px 24px;
        }
    }

    /* Individual Location Item */
    #shopify-section-{{ section.id }} .store-locations__item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        text-decoration: none;
        transition: opacity 0.2s ease;
        position: relative;
        padding: 0 16px;
    }

    /* Dividing line between items */
    #shopify-section-{{ section.id }} .store-locations__item:not(:last-child)::after {
        content: '';
        position: absolute;
        right: 0;
        top: 10%;
        height: 80%;
        width: 1px;
        background-color: {{ section.settings.border_color }};
    }

    /* Hide divider on mobile for grid layout */
    @media (max-width: 479px) {
        #shopify-section-{{ section.id }} .store-locations__item:nth-child(2n)::after {
            display: none;
        }
    }

    @media (min-width: 480px) and (max-width: 767px) {
        #shopify-section-{{ section.id }} .store-locations__item:nth-child(3n)::after {
            display: none;
        }
    }

    #shopify-section-{{ section.id }} .store-locations__item:hover {
        opacity: 0.7;
    }

    /* Icon */
    #shopify-section-{{ section.id }} .store-locations__icon {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
    }

    #shopify-section-{{ section.id }} .store-locations__icon img,
    #shopify-section-{{ section.id }} .store-locations__icon svg {
        width: {{ section.settings.icon_size_mobile }}px;
        height: {{ section.settings.icon_size_mobile }}px;
        object-fit: contain;
    }

    @media (min-width: 768px) {
        #shopify-section-{{ section.id }} .store-locations__icon img,
        #shopify-section-{{ section.id }} .store-locations__icon svg {
            width: {{ section.settings.icon_size_desktop }}px;
            height: {{ section.settings.icon_size_desktop }}px;
        }
    }

    /* Label */
    #shopify-section-{{ section.id }} .store-locations__label {
        font-size: 13px;
        font-weight: 500;
        color: {{ section.settings.label_color }};
        line-height: 1.4;
    }

    @media (min-width: 768px) {
        #shopify-section-{{ section.id }} .store-locations__label {
            font-size: 14px;
        }
    }
{%- endstyle -%}

<section class="store-locations">
    {%- if section.settings.heading != blank -%}
        <h2 class="store-locations__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="store-locations__container">
        <div class="store-locations__grid">
            {%- for block in section.blocks -%}
                {%- if block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}" class="store-locations__item focus-visible-outline" {{ block.shopify_attributes }}>
                {%- else -%}
                    <div class="store-locations__item" {{ block.shopify_attributes }}>
                {%- endif -%}

                    {%- if block.settings.icon != blank -%}
                        <div class="store-locations__icon">
                            {{ block.settings.icon | image_url: width: 200 | image_tag }}
                        </div>
                    {%- else -%}
                        <div class="store-locations__icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.label_color }}" stroke-width="1.5">
                                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                                <circle cx="12" cy="9" r="2.5"/>
                            </svg>
                        </div>
                    {%- endif -%}

                    {%- if block.settings.label != blank -%}
                        <span class="store-locations__label">{{ block.settings.label }}</span>
                    {%- endif -%}

                {%- if block.settings.link != blank -%}
                    </a>
                {%- else -%}
                    </div>
                {%- endif -%}
            {%- endfor -%}

            {%- if section.blocks.size == 0 -%}
                {%- for i in (1..6) -%}
                    <div class="store-locations__item">
                        <div class="store-locations__icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.label_color }}" stroke-width="1.5">
                                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                                <circle cx="12" cy="9" r="2.5"/>
                            </svg>
                        </div>
                        <span class="store-locations__label">City {{ i }}</span>
                    </div>
                {%- endfor -%}
            {%- endif -%}
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Store Locations",
    "settings": [
        {
            "type": "header",
            "content": "Content"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Shop at Store"
        },
        {
            "type": "range",
            "id": "heading_font_size_desktop",
            "min": 20,
            "max": 60,
            "step": 2,
            "unit": "px",
            "label": "Heading Font Size (Desktop)",
            "default": 28
        },
        {
            "type": "range",
            "id": "heading_font_size_mobile",
            "min": 18,
            "max": 36,
            "step": 2,
            "unit": "px",
            "label": "Heading Font Size (Mobile)",
            "default": 22
        },
        {
            "type": "select",
            "id": "heading_alignment",
            "label": "Heading Alignment",
            "options": [
                {
                    "value": "left",
                    "label": "Left"
                },
                {
                    "value": "center",
                    "label": "Center"
                },
                {
                    "value": "right",
                    "label": "Right"
                }
            ],
            "default": "left"
        },
        {
            "type": "header",
            "content": "Icons"
        },
        {
            "type": "range",
            "id": "icon_size_desktop",
            "min": 32,
            "max": 80,
            "step": 4,
            "unit": "px",
            "label": "Icon Size (Desktop)",
            "default": 48
        },
        {
            "type": "range",
            "id": "icon_size_mobile",
            "min": 28,
            "max": 60,
            "step": 4,
            "unit": "px",
            "label": "Icon Size (Mobile)",
            "default": 40
        },
        {
            "type": "header",
            "content": "Colors"
        },
        {
            "type": "color",
            "id": "background_color",
            "label": "Section Background",
            "default": "#ffffff"
        },
        {
            "type": "color",
            "id": "heading_color",
            "label": "Heading Color",
            "default": "#2C3E50"
        },
        {
            "type": "color",
            "id": "label_color",
            "label": "Label Color",
            "default": "#5A6A7A"
        },
        {
            "type": "color",
            "id": "border_color",
            "label": "Border Color",
            "default": "#E0E0E0"
        },
        {
            "type": "range",
            "id": "border_radius",
            "min": 0,
            "max": 20,
            "step": 2,
            "unit": "px",
            "label": "Border Radius",
            "default": 4
        },
        {
            "type": "header",
            "content": "Layout"
        },
        {
            "type": "range",
            "id": "max_width",
            "min": 800,
            "max": 1600,
            "step": 50,
            "unit": "px",
            "label": "Max Section Width",
            "default": 1400
        },
        {
            "type": "range",
            "id": "padding_top_desktop",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "Padding Top (Desktop)",
            "default": 40
        },
        {
            "type": "range",
            "id": "padding_bottom_desktop",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "Padding Bottom (Desktop)",
            "default": 40
        },
        {
            "type": "range",
            "id": "padding_top_mobile",
            "min": 0,
            "max": 80,
            "step": 4,
            "unit": "px",
            "label": "Padding Top (Mobile)",
            "default": 24
        },
        {
            "type": "range",
            "id": "padding_bottom_mobile",
            "min": 0,
            "max": 80,
            "step": 4,
            "unit": "px",
            "label": "Padding Bottom (Mobile)",
            "default": 24
        }
    ],
    "blocks": [
        {
            "type": "location",
            "name": "Store Location",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "icon",
                    "label": "City Icon"
                },
                {
                    "type": "text",
                    "id": "label",
                    "label": "City Name",
                    "default": "City Name"
                },
                {
                    "type": "url",
                    "id": "link",
                    "label": "Link (optional)"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Store Locations",
            "settings": {
                "heading": "Shop at Store"
            },
            "blocks": [
                {
                    "type": "location",
                    "settings": {
                        "label": "Mumbai"
                    }
                },
                {
                    "type": "location",
                    "settings": {
                        "label": "Delhi"
                    }
                },
                {
                    "type": "location",
                    "settings": {
                        "label": "Bangalore"
                    }
                },
                {
                    "type": "location",
                    "settings": {
                        "label": "Chennai"
                    }
                },
                {
                    "type": "location",
                    "settings": {
                        "label": "Hyderabad"
                    }
                },
                {
                    "type": "location",
                    "settings": {
                        "label": "Kolkata"
                    }
                }
            ]
        }
    ]
}
{% endschema %}
