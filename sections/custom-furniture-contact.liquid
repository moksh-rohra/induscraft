{%- comment -%}
------------------------------------------------------------------------------
	Section: Custom Furniture Contact Form
	A contact form for custom furniture inquiries with image upload
	Uses Basin for file upload support
------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign heading = section.settings.heading -%}
{%- assign description = section.settings.description -%}
{%- assign basin_endpoint = section.settings.basin_endpoint | default: 'https://usebasin.com/f/febcfee93f80' -%}

<style>
	#custom-furniture-form-{{ section.id }} {
		padding: {{ section.settings.padding_top_mobile }}px 20px {{ section.settings.padding_bottom_mobile }}px;
		background-color: {{ section.settings.bg_color }};
	}

	@media (min-width: 768px) {
		#custom-furniture-form-{{ section.id }} {
			padding: {{ section.settings.padding_top_desktop }}px 60px {{ section.settings.padding_bottom_desktop }}px;
		}
	}

	.custom-furniture-form {
		max-width: 700px;
		margin: 0 auto;
	}

	.custom-furniture-form__header {
		text-align: center;
		margin-bottom: 40px;
	}

	.custom-furniture-form__heading {
		font-family: var(--heading-font-family);
		font-size: {{ section.settings.heading_size_mobile }}px;
		font-weight: var(--heading-font-weight, 600);
		color: {{ section.settings.heading_color }};
		margin: 0 0 16px 0;
		line-height: 1.2;
	}

	@media (min-width: 768px) {
		.custom-furniture-form__heading {
			font-size: {{ section.settings.heading_size_desktop }}px;
		}
	}

	.custom-furniture-form__description {
		font-size: 16px;
		line-height: 1.6;
		color: {{ section.settings.description_color }};
		margin: 0;
	}

	.custom-furniture-form__form {
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.custom-furniture-form__row {
		display: flex;
		gap: 16px;
	}

	@media (max-width: 767px) {
		.custom-furniture-form__row {
			flex-direction: column;
		}
	}

	.custom-furniture-form__row .custom-furniture-form__group {
		flex: 1;
	}

	.custom-furniture-form__group {
		display: flex;
		flex-direction: column;
	}

	.custom-furniture-form__label {
		font-size: 14px;
		font-weight: 500;
		color: {{ section.settings.label_color }};
		margin-bottom: 8px;
	}

	.custom-furniture-form__label .required {
		color: #e53935;
		margin-left: 2px;
	}

	.custom-furniture-form__label .optional {
		color: #888;
		font-weight: 400;
		font-size: 13px;
	}

	.custom-furniture-form__input,
	.custom-furniture-form__textarea {
		width: 100%;
		padding: 14px 16px;
		border: 1px solid {{ section.settings.input_border_color }};
		border-radius: 8px;
		font-size: 15px;
		font-family: inherit;
		background: #fff;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
		box-sizing: border-box;
	}

	.custom-furniture-form__input:focus,
	.custom-furniture-form__textarea:focus {
		outline: none;
		border-color: var(--color-primary, #8B7355);
		box-shadow: 0 0 0 3px rgba(139, 115, 85, 0.1);
	}

	.custom-furniture-form__input::placeholder,
	.custom-furniture-form__textarea::placeholder {
		color: #999;
	}

	.custom-furniture-form__textarea {
		min-height: 140px;
		resize: vertical;
	}

	/* File Upload Styles */
	.custom-furniture-form__file-wrapper {
		position: relative;
	}

	.custom-furniture-form__file-input {
		position: absolute;
		opacity: 0;
		width: 100%;
		height: 100%;
		cursor: pointer;
		z-index: 2;
		top: 0;
		left: 0;
	}

	.custom-furniture-form__file-label {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 30px 20px;
		border: 2px dashed {{ section.settings.input_border_color }};
		border-radius: 12px;
		background: #fafafa;
		cursor: pointer;
		transition: border-color 0.2s ease, background-color 0.2s ease;
		text-align: center;
	}

	.custom-furniture-form__file-wrapper:hover .custom-furniture-form__file-label {
		border-color: var(--color-primary, #8B7355);
		background: #f5f5f5;
	}

	.custom-furniture-form__file-icon {
		width: 48px;
		height: 48px;
		margin-bottom: 12px;
		color: #888;
	}

	.custom-furniture-form__file-text {
		font-size: 15px;
		color: #666;
		margin-bottom: 4px;
	}

	.custom-furniture-form__file-hint {
		font-size: 13px;
		color: #999;
	}

	.custom-furniture-form__file-name {
		margin-top: 12px;
		padding: 10px 16px;
		background: #e8f5e9;
		border-radius: 6px;
		font-size: 14px;
		color: #2e7d32;
		display: none;
	}

	.custom-furniture-form__file-name.has-file {
		display: block;
	}

	/* Preview Image */
	.custom-furniture-form__preview {
		margin-top: 12px;
		display: none;
	}

	.custom-furniture-form__preview.has-preview {
		display: block;
	}

	.custom-furniture-form__preview img {
		max-width: 200px;
		max-height: 150px;
		border-radius: 8px;
		object-fit: cover;
		border: 1px solid #ddd;
	}

	/* Button wrapper for alignment */
	.custom-furniture-form__button-wrapper {
		align-self: flex-start;
	}

	/* Success Message */
	.custom-furniture-form__success {
		padding: 20px;
		background: #e8f5e9;
		border-radius: 8px;
		color: #2e7d32;
		text-align: center;
		font-size: 16px;
		margin-bottom: 20px;
		display: none;
	}

	.custom-furniture-form__success.show {
		display: block;
	}

	/* Error Message */
	.custom-furniture-form__error {
		padding: 16px;
		background: #ffebee;
		border-radius: 8px;
		color: #c62828;
		font-size: 14px;
		margin-bottom: 20px;
		display: none;
	}

	.custom-furniture-form__error.show {
		display: block;
	}
</style>

<section id="custom-furniture-form-{{ section.id }}">
	<div class="custom-furniture-form">
		<div class="custom-furniture-form__header">
			{%- if heading != blank -%}
				<h2 class="custom-furniture-form__heading">{{ heading }}</h2>
			{%- endif -%}
			
			{%- if description != blank -%}
				<p class="custom-furniture-form__description">{{ description }}</p>
			{%- endif -%}
		</div>

		<!-- Success Message -->
		<div class="custom-furniture-form__success" id="cf-success-{{ section.id }}">
			{{ section.settings.success_message }}
		</div>

		<!-- Error Message -->
		<div class="custom-furniture-form__error" id="cf-error-{{ section.id }}">
			Something went wrong. Please try again.
		</div>

		<!-- Basin Form -->
		<form 
			action="{{ basin_endpoint }}"
			method="POST"
			enctype="multipart/form-data"
			class="custom-furniture-form__form"
			id="cf-form-{{ section.id }}"
		>
			<div class="custom-furniture-form__row">
				<div class="custom-furniture-form__group">
					<label class="custom-furniture-form__label" for="cf-first-name-{{ section.id }}">
						{{ section.settings.first_name_label }}<span class="required">*</span>
					</label>
					<input 
						type="text" 
						id="cf-first-name-{{ section.id }}"
						name="first_name" 
						class="custom-furniture-form__input"
						required
					>
				</div>
				<div class="custom-furniture-form__group">
					<label class="custom-furniture-form__label" for="cf-last-name-{{ section.id }}">
						{{ section.settings.last_name_label }}<span class="required">*</span>
					</label>
					<input 
						type="text" 
						id="cf-last-name-{{ section.id }}"
						name="last_name" 
						class="custom-furniture-form__input"
						required
					>
				</div>
			</div>

			<div class="custom-furniture-form__row">
				<div class="custom-furniture-form__group">
					<label class="custom-furniture-form__label" for="cf-email-{{ section.id }}">
						{{ section.settings.email_label }}<span class="required">*</span>
					</label>
					<input 
						type="email" 
						id="cf-email-{{ section.id }}"
						name="email" 
						class="custom-furniture-form__input"
						required
					>
				</div>
				<div class="custom-furniture-form__group">
					<label class="custom-furniture-form__label" for="cf-phone-{{ section.id }}">
						{{ section.settings.phone_label }} <span class="optional">(Optional)</span>
					</label>
					<input 
						type="tel" 
						id="cf-phone-{{ section.id }}"
						name="phone" 
						class="custom-furniture-form__input"
					>
				</div>
			</div>

			<div class="custom-furniture-form__group">
				<label class="custom-furniture-form__label" for="cf-message-{{ section.id }}">
					{{ section.settings.message_label }}<span class="required">*</span>
				</label>
				<textarea 
					id="cf-message-{{ section.id }}"
					name="message" 
					class="custom-furniture-form__textarea"
					required
				></textarea>
			</div>

			<div class="custom-furniture-form__group">
				<label class="custom-furniture-form__label">
					{{ section.settings.image_label }} <span class="optional">(Optional)</span>
				</label>
				<div class="custom-furniture-form__file-wrapper">
					<input 
						type="file" 
						id="cf-image-{{ section.id }}"
						name="reference_image" 
						class="custom-furniture-form__file-input"
						accept="image/*"
					>
					<div class="custom-furniture-form__file-label">
						<svg class="custom-furniture-form__file-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
						</svg>
						<span class="custom-furniture-form__file-text">Click to upload or drag and drop</span>
						<span class="custom-furniture-form__file-hint">PNG, JPG, WEBP up to 10MB</span>
					</div>
					<div class="custom-furniture-form__file-name" id="cf-file-name-{{ section.id }}"></div>
					<div class="custom-furniture-form__preview" id="cf-preview-{{ section.id }}">
						<img id="cf-preview-img-{{ section.id }}" src="" alt="Preview" width="100" height="100">
					</div>
				</div>
			</div>

			<div class="custom-furniture-form__button-wrapper">
				<button type="submit" class="button-new button--{{ section.settings.button_style }}" id="cf-submit-{{ section.id }}">
					{{ section.settings.submit_label }}
				</button>
			</div>
		</form>

		<script>
			(function() {
				const sectionId = '{{ section.id }}';
				const fileInput = document.getElementById('cf-image-' + sectionId);
				const fileNameEl = document.getElementById('cf-file-name-' + sectionId);
				const previewEl = document.getElementById('cf-preview-' + sectionId);
				const previewImg = document.getElementById('cf-preview-img-' + sectionId);
				const successEl = document.getElementById('cf-success-' + sectionId);
				const form = document.getElementById('cf-form-' + sectionId);

				// File preview functionality
				if (fileInput) {
					fileInput.addEventListener('change', function(e) {
						const file = e.target.files[0];
						if (file) {
							// Show file name
							fileNameEl.textContent = file.name;
							fileNameEl.classList.add('has-file');

							// Show preview
							const reader = new FileReader();
							reader.onload = function(e) {
								previewImg.src = e.target.result;
								previewEl.classList.add('has-preview');
							};
							reader.readAsDataURL(file);
						} else {
							fileNameEl.textContent = '';
							fileNameEl.classList.remove('has-file');
							previewEl.classList.remove('has-preview');
						}
					});
				}

				// Check for success redirect (Basin adds #success to URL after submission)
				if (window.location.hash === '#success' || window.location.search.includes('success')) {
					successEl.classList.add('show');
					form.style.display = 'none';
					
					// Clean URL
					const cleanUrl = window.location.pathname;
					window.history.replaceState({}, document.title, cleanUrl);
					
					// Scroll to success message
					successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
				}
			})();
		</script>
	</div>
</section>

{% schema %}
{
	"name": "Custom Furniture Form",
	"settings": [
		{
			"type": "header",
			"content": "Basin Integration"
		},
		{
			"type": "text",
			"id": "basin_endpoint",
			"label": "Basin Form Endpoint URL",
			"default": "https://usebasin.com/f/febcfee93f80",
			"info": "Get your endpoint from usebasin.com"
		},
		{
			"type": "header",
			"content": "Content"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Custom Furniture Inquiry"
		},
		{
			"type": "range",
			"id": "heading_size_desktop",
			"min": 24,
			"max": 72,
			"step": 2,
			"unit": "px",
			"label": "Heading Size (Desktop)",
			"default": 40
		},
		{
			"type": "range",
			"id": "heading_size_mobile",
			"min": 20,
			"max": 48,
			"step": 2,
			"unit": "px",
			"label": "Heading Size (Mobile)",
			"default": 28
		},
		{
			"type": "textarea",
			"id": "description",
			"label": "Description",
			"default": "Have a custom furniture design in mind? Share your vision with us and we'll bring it to life."
		},
		{
			"type": "header",
			"content": "Form Labels"
		},
		{
			"type": "text",
			"id": "first_name_label",
			"label": "First Name Label",
			"default": "First Name"
		},
		{
			"type": "text",
			"id": "last_name_label",
			"label": "Last Name Label",
			"default": "Last Name"
		},
		{
			"type": "text",
			"id": "email_label",
			"label": "Email Label",
			"default": "Email"
		},
		{
			"type": "text",
			"id": "phone_label",
			"label": "Phone Label",
			"default": "Phone Number"
		},
		{
			"type": "text",
			"id": "message_label",
			"label": "Message Label",
			"default": "Describe Your Custom Furniture"
		},
		{
			"type": "text",
			"id": "image_label",
			"label": "Image Upload Label",
			"default": "Upload Reference Image"
		},
		{
			"type": "text",
			"id": "submit_label",
			"label": "Submit Button Text",
			"default": "Submit Inquiry"
		},
		{
			"type": "select",
			"id": "button_style",
			"label": "Button Style",
			"options": [
				{
					"value": "primary",
					"label": "Primary (Double Border)"
				},
				{
					"value": "secondary",
					"label": "Secondary"
				}
			],
			"default": "primary"
		},
		{
			"type": "text",
			"id": "success_message",
			"label": "Success Message",
			"default": "Thank you for your inquiry! We'll review your request and get back to you soon."
		},
		{
			"type": "header",
			"content": "Colors"
		},
		{
			"type": "color",
			"id": "bg_color",
			"label": "Background Color",
			"default": "#ffffff"
		},
		{
			"type": "color",
			"id": "heading_color",
			"label": "Heading Color",
			"default": "#2C2A28"
		},
		{
			"type": "color",
			"id": "description_color",
			"label": "Description Color",
			"default": "#666666"
		},
		{
			"type": "color",
			"id": "label_color",
			"label": "Label Color",
			"default": "#333333"
		},
		{
			"type": "color",
			"id": "input_border_color",
			"label": "Input Border Color",
			"default": "#dddddd"
		},
		{
			"type": "header",
			"content": "Spacing"
		},
		{
			"type": "range",
			"id": "padding_top_desktop",
			"min": 0,
			"max": 100,
			"step": 5,
			"unit": "px",
			"label": "Desktop Padding Top",
			"default": 60
		},
		{
			"type": "range",
			"id": "padding_bottom_desktop",
			"min": 0,
			"max": 100,
			"step": 5,
			"unit": "px",
			"label": "Desktop Padding Bottom",
			"default": 60
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 5,
			"unit": "px",
			"label": "Mobile Padding Top",
			"default": 40
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 5,
			"unit": "px",
			"label": "Mobile Padding Bottom",
			"default": 40
		}
	],
	"presets": [
		{
			"name": "Custom Furniture Form"
		}
	]
}
{% endschema %}
