{%- comment -%}
  Animated Gallery Card Section
  -----------------------------
  A pinned section where 3 images appear, then stack to the right,
  revealing content on the left.
{%- endcomment -%}

{{ 'animated-gallery-card.css' | asset_url | stylesheet_tag }}

<section 
  id="gallery-card-{{ section.id }}"
  class="gallery-card-section"
  data-section-id="{{ section.id }}"
  style="--bg-color: {{ section.settings.bg_color }}; --text-color: {{ section.settings.text_color }}; --scrolled-bg-color: {{ section.settings.scrolled_bg_color }}"
>
  <div class="gallery-card__wrapper">
    <!-- Images Container -->
    <div class="gallery-card__images">
      <!-- Card 1 -->
      <div class="gallery-card__image-card card-1">
        {%- if section.settings.image_1 != blank -%}
          {{ section.settings.image_1 | image_url: width: 800 | image_tag: class: 'gallery-card__image' }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'gallery-card__image' }}
        {%- endif -%}
      </div>
      
      <!-- Card 2 -->
      <div class="gallery-card__image-card card-2">
        {%- if section.settings.image_2 != blank -%}
          {{ section.settings.image_2 | image_url: width: 800 | image_tag: class: 'gallery-card__image' }}
        {%- else -%}
          {{ 'product-2' | placeholder_svg_tag: 'gallery-card__image' }}
        {%- endif -%}
      </div>
      
      <!-- Card 3 -->
      <div class="gallery-card__image-card card-3">
        {%- if section.settings.image_3 != blank -%}
          {{ section.settings.image_3 | image_url: width: 800 | image_tag: class: 'gallery-card__image' }}
        {%- else -%}
          {{ 'product-3' | placeholder_svg_tag: 'gallery-card__image' }}
        {%- endif -%}
      </div>
    </div>

    <!-- Content (Initially Hidden) -->
    <div class="gallery-card__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="gallery-card__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.text != blank -%}
        <div class="gallery-card__text">{{ section.settings.text }}</div>
      {%- endif -%}
      
      {%- if section.settings.button_label != blank -%}
        {%- if section.settings.button_style == 'circle' -%}
          <a href="{{ section.settings.button_url }}" class="button-circle" aria-label="{{ section.settings.button_label }}">
            <span class="button__text">{{ section.settings.button_label }}</span>
            <span class="button-new__icon-container">
              <span class="button-new__icon-wrapper">
                {% render 'icons-new', icon: 'arrow-right' %}
              </span>
            </span>
          </a>
        {%- else -%}
          <a href="{{ section.settings.button_url }}" class="button-new button--{{ section.settings.button_style }}">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</section>

<!-- Register GSAP if not already registered (conditionally) -->
<script>
  (function() {
    const sectionId = '{{ section.id }}';
    
    function initGalleryAnimation() {
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

      const section = document.querySelector(`#gallery-card-${sectionId}`);
      if (!section) return;

      const images = section.querySelectorAll('.gallery-card__image-card');
      const content = section.querySelector('.gallery-card__content');
      const card2 = section.querySelector('.card-2');
      const card3 = section.querySelector('.card-3');
      const contentChildren = content.children;

      // Mobile check
      const mm = gsap.matchMedia();
      
      mm.add("(min-width: 769px)", () => {
        // Main Timeline
        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: section,
            pin: true,
            start: "top top",
            end: "+=200%", // Scroll distance
            scrub: 1,
            anticipatePin: 1
          }
        });

        // Step 1: Stagger In Images (from bottom)
        tl.from(images, {
          yPercent: 100,
          duration: 1,
          stagger: 0.2,
          ease: "power2.out"
        });

        // Step 2: Stack Images to the Right
        // We need to move Card 1 and Card 2 to align with Card 3
        // Since we are using flex, calculating precise pixels can be tricky.
        // A robust way works if we know the positions. 
        // Or simpler: translate x percentage.
        // 3 columns: Card 1 is at 0%, Card 2 at ~33%, Card 3 at ~66%.
        // To stack on Card 3:
        // Card 1 needs to move 200% width + gaps? 
        // Let's use xPercent assuming equal widths.
        
        // Actually, let's use layout logic:
        // Get the gap+width. 
        // Simpler approach: Move them to absolute overlap or just approximate xPercent.
        // Assuming 3 equal columns with gap 20px.
        
        // Let's try xPercent relative to self width.
        // Card 1 needs to move past Card 2 to Card 3.
        // If flex-basis is equal, Card 1 moves 2 slots. Card 2 moves 1 slot.
        // (100% width + gap) * 2 roughly?
        // Since gap is 20px, percentages are safer for responsiveness if we assume container is reference.
        // Actually, easier solution for stacking: 
        // 1. Move Card 1 to Card 3 position.
        // 2. Move Card 2 to Card 3 position.
        
        // Using xPercent calculation might need adjustment, let's estimate 105% per card slot 
        // (100% width + small gap relative to width).
        
        tl.to('.card-1', {
          x: () => {
             // Calculate distance to Card 3
             const c1 = section.querySelector('.card-1').getBoundingClientRect();
             const c3 = section.querySelector('.card-3').getBoundingClientRect();
             return (c3.left - c1.left) - 60;
          },
          duration: 1,
          ease: "power2.inOut"
        }, 'stack');

        tl.to('.card-2', {
          x: () => {
             const c2 = section.querySelector('.card-2').getBoundingClientRect();
             const c3 = section.querySelector('.card-3').getBoundingClientRect();
             return (c3.left - c2.left) - 60;
          },
          duration: 1,
          ease: "power2.inOut"
        }, 'stack');

        tl.to('.card-3', {
          x: -60,
          duration: 1,
          ease: "power2.inOut"
        }, 'stack');

        // Optional: Rotate/Scale slightly for messy stack look
        tl.to('.card-1', { rotation: -3, scale: 0.95, duration: 1 }, 'stack');
        tl.to('.card-2', { rotation: 2, scale: 0.98, duration: 1 }, 'stack');

        // Background Color Change
        tl.to(section, {
          backgroundColor: 'var(--scrolled-bg-color)',
          color: '#111111', 
          duration: 1,
          ease: "power2.inOut"
        }, 'stack');

        // Step 3: Reveal Content on Left
        tl.to(content, {
          autoAlpha: 1,
          duration: 0.5
        }, 'stack+=0.5');
        
        tl.from(contentChildren, {
          y: 20,
          opacity: 0,
          stagger: 0.1,
          duration: 0.5
        }, 'stack+=0.5');

      });
    }

    document.addEventListener('DOMContentLoaded', initGalleryAnimation);
    document.addEventListener('shopify:section:load', initGalleryAnimation);
  })();
</script>

{% schema %}
{
  "name": "Animated Gallery Card",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 (First)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (Middle)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 (Last/Base)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Recent Work"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Discover our latest interior design projects that blend functionality with aesthetic perfection."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "View All Projects"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "options": [
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        },
        {
          "value": "circle",
          "label": "Circle"
        }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "scrolled_bg_color",
      "label": "Scrolled Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Animated Gallery Card"
    }
  ]
}
{% endschema %}
