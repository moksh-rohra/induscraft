{% style %}
    #shopify-section-{{ section.id }} {
        padding-top: {{ section.settings.offset_top_mobile }}px;
        padding-bottom: {{ section.settings.offset_bottom_mobile }}px;
    }

    @media screen and (min-width: 768px) {
        #shopify-section-{{ section.id }} {
            padding-top: {{ section.settings.offset_top_desktop }}px;
            padding-bottom: {{ section.settings.offset_bottom_desktop }}px;
        }
    }

    .promo-category-grid {
        max-width: var(--global-container-width);
        margin: 0 auto;
        padding: 0 60px;
    }

    .promo-category-grid__container {
        display: grid;
        gap: 20px;
        grid-template-columns: 1fr;
    }

    @media (min-width: 768px) {
        .promo-category-grid__container {
            grid-template-columns: 1fr 1fr;
            gap: 24px;
        }
    }

    @media (max-width: 767px) {
        .promo-category-grid {
            padding: 0 16px;
        }
    }

    /* Promo Card */
    .promo-card {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        min-height: 400px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 40px;
        background: #2c2a28;
        color: #fff;
    }

    @media (min-width: 768px) {
        .promo-card {
            min-height: 500px;
        }
    }

    .promo-card__image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    .promo-card__overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, var(--overlay-opacity, 0.3));
        z-index: 1;
    }

    .promo-card__content {
        position: relative;
        z-index: 2;
    }

    .promo-card__heading {
        font-size: 48px;
        font-weight: 700;
        line-height: 1.1;
        margin: 0 0 0 0;
        color: inherit;
    }

    .promo-card__discount {
        font-size: 32px;
        font-weight: 700;
        margin: 0 0 8px 0;
        color: inherit;
    }

    .promo-card__discount-number {
        font-size: 56px;
        color: #ff4444;
    }

    .promo-card__end-date {
        font-size: 24px;
        font-weight: 600;
        margin: 0 0 24px 0;
        color: inherit;
    }

    .promo-card__end-date-number {
        font-size: 32px;
        color: #ff4444;
    }

    /* Promo Card Button - inherits theme default button styles via button--primary/secondary classes */


    /* Category Cards Grid */
    .category-cards {
        display: grid;
        gap: 20px;
        grid-template-columns: 1fr;
    }

    @media (min-width: 768px) {
        .category-cards {
            grid-template-columns: 1fr 1fr;
            gap: 24px;
        }
    }

    .category-card {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        min-height: 320px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        transition: transform 0.3s ease;
    }

    .category-card__header {
        position: relative;
        z-index: 2;
        margin-bottom: auto;
    }

    .category-card__heading {
        font-size: var(--heading-size-desktop, 28px) !important;
        font-weight: 700;
        margin: 0 0 4px 0;
        color: #fff;
    }

    .category-card__price {
        font-size: var(--price-size-desktop, 16px) !important;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.9);
    }

    @media (max-width: 767px) {
        .category-card__heading {
            font-size: var(--heading-size-mobile, 24px) !important;
        }
        
        .category-card__price {
            font-size: var(--price-size-mobile, 14px) !important;
        }
    }

    .category-card__image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    .category-card__overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.1) 100%);
        z-index: 1;
    }

    .category-card__arrow {
        position: absolute;
        top: 24px;
        right: 24px;
        width: 45px;
        height: 45px;
        background: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 3;
        transition: transform 0.3s ease;
        transform: rotate(-35deg);
    }

    .category-card:hover .category-card__arrow {
        transform: scale(1.1) ;
    }

    .category-card__arrow svg {
        width: 20px;
        height: 20px;
        stroke: #2c2a28;
        stroke-width: 2;
        fill: none;
    }

    @media (max-width: 767px) {
        .promo-card__heading {
            font-size: 32px;
        }
        .promo-card__discount {
            font-size: 24px;
        }
        .promo-card__discount-number {
            font-size: 40px;
        }
        .promo-card__end-date {
            font-size: 18px;
        }
        .promo-card__end-date-number {
            font-size: 24px;
        }
    }
{% endstyle %}

<div class="promo-category-grid">
    <div class="promo-category-grid__container">
        {%- for block in section.blocks -%}
            {%- if block.type == 'promo_card' -%}
                <div class="promo-card" style="--overlay-opacity: {{ block.settings.overlay_opacity }};">
                    {%- if block.settings.background_image != blank -%}
                        {{ block.settings.background_image | image_url: width: 1000 | image_tag: class: 'promo-card__image', loading: 'lazy', sizes: '(min-width: 768px) 50vw, 100vw', widths: '375, 550, 750, 1000' }}
                    {%- endif -%}
                    <div class="promo-card__overlay"></div>
                    <div class="promo-card__content">
                        {%- if block.settings.heading != blank -%}
                            <h2 class="promo-card__heading">{{ block.settings.heading }}</h2>
                        {%- endif -%}
                        {%- if block.settings.discount_text != blank -%}
                            <div class="promo-card__discount">
                                {{ block.settings.discount_text }}
                                {%- if block.settings.discount_number != blank -%}
                                    <span class="promo-card__discount-number">{{ block.settings.discount_number }}</span>
                                {%- endif -%}
                            </div>
                        {%- endif -%}
                        {%- if block.settings.end_date_text != blank -%}
                            <div class="promo-card__end-date">
                                {{ block.settings.end_date_text }}
                                {%- if block.settings.end_date_number != blank -%}
                                    <span class="promo-card__end-date-number">{{ block.settings.end_date_number }}</span>
                                {%- endif -%}
                            </div>
                        {%- endif -%}
                        {%- if block.settings.button_text != blank -%}
                            <a href="{{ block.settings.button_link | default: '#' }}" class="promo-card__button button-new button--{{ block.settings.button_style }}">
                                {{ block.settings.button_text }}
                            </a>
                        {%- endif -%}
                    </div>
                </div>
            {%- endif -%}
        {%- endfor -%}

        <div class="category-cards">
            {%- for block in section.blocks -%}
                {%- if block.type == 'category_card' -%}
                    <a href="{{ block.settings.link | default: '#' }}" 
                       class="category-card" 
                       style="background-color: {{ block.settings.background_color }}; --heading-size-desktop: {{ block.settings.heading_font_size_desktop }}px; --heading-size-mobile: {{ block.settings.heading_font_size_mobile }}px; --price-size-desktop: {{ block.settings.price_font_size_desktop }}px; --price-size-mobile: {{ block.settings.price_font_size_mobile }}px;">
                        {%- if block.settings.product_image != blank -%}
                            {{ block.settings.product_image | image_url: width: 800 | image_tag: class: 'category-card__image', loading: 'lazy', sizes: '(min-width: 768px) 25vw, 50vw', widths: '375, 550, 750, 800' }}
                            <div class="category-card__overlay"></div>
                        {%- endif -%}
                        <div class="category-card__header">
                            {%- if block.settings.heading != blank -%}
                                <h3 class="category-card__heading">{{ block.settings.heading }}</h3>
                            {%- endif -%}
                            {%- if block.settings.price_text != blank -%}
                                <div class="category-card__price">{{ block.settings.price_text }}</div>
                            {%- endif -%}
                        </div>
                        <div class="category-card__arrow">
                            <svg viewBox="0 0 24 24">
                                <path d="M5 12h14M12 5l7 7-7 7"/>
                            </svg>
                        </div>
                    </a>
                {%- endif -%}
            {%- endfor -%}
        </div>
    </div>
</div>

{% schema %}
{
    "name": "Promo Category Grid",
    "settings": [
        {
            "type": "header",
            "content": "Padding"
        },
        {
            "type": "range",
            "id": "offset_top_desktop",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Desktop offset top",
            "default": 60
        },
        {
            "type": "range",
            "id": "offset_bottom_desktop",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Desktop offset bottom",
            "default": 60
        },
        {
            "type": "range",
            "id": "offset_top_mobile",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Mobile offset top",
            "default": 40
        },
        {
            "type": "range",
            "id": "offset_bottom_mobile",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Mobile offset bottom",
            "default": 40
        }
    ],
    "blocks": [
        {
            "type": "promo_card",
            "name": "Promo Card",
            "limit": 1,
            "settings": [
                {
                    "type": "image_picker",
                    "id": "background_image",
                    "label": "Background Image"
                },
                {
                    "type": "range",
                    "id": "overlay_opacity",
                    "min": 0,
                    "max": 1,
                    "step": 0.1,
                    "label": "Overlay Opacity",
                    "default": 0.3
                },
                {
                    "type": "text",
                    "id": "heading",
                    "label": "Heading",
                    "default": "Full House Fiesta"
                },
                {
                    "type": "text",
                    "id": "discount_text",
                    "label": "Discount Text",
                    "default": "up to"
                },
                {
                    "type": "text",
                    "id": "discount_number",
                    "label": "Discount Number",
                    "default": "70% off"
                },
                {
                    "type": "text",
                    "id": "end_date_text",
                    "label": "End Date Text",
                    "default": "ENDS ON"
                },
                {
                    "type": "text",
                    "id": "end_date_number",
                    "label": "End Date Number",
                    "default": "4TH JAN"
                },
                {
                    "type": "text",
                    "id": "button_text",
                    "label": "Button Text",
                    "default": "SHOP NOW"
                },
                {
                    "type": "select",
                    "id": "button_style",
                    "label": "Button Style",
                    "options": [
                        {
                            "value": "primary",
                            "label": "Primary"
                        },
                        {
                            "value": "secondary",
                            "label": "Secondary"
                        }
                    ],
                    "default": "primary"
                },
                {
                    "type": "url",
                    "id": "button_link",
                    "label": "Button Link"
                }
            ]
        },
        {
            "type": "category_card",
            "name": "Category Card",
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "Heading",
                    "default": "Category"
                },
                {
                    "type": "text",
                    "id": "price_text",
                    "label": "Price Text",
                    "default": "from ₹9,999"
                },
                {
                    "type": "image_picker",
                    "id": "product_image",
                    "label": "Product Image"
                },
                {
                    "type": "color",
                    "id": "background_color",
                    "label": "Background Color",
                    "default": "#2d6a4f"
                },
                {
                    "type": "header",
                    "content": "Typography"
                },
                {
                    "type": "range",
                    "id": "heading_font_size_desktop",
                    "min": 16,
                    "max": 48,
                    "step": 1,
                    "unit": "px",
                    "label": "Heading Font Size (Desktop)",
                    "default": 28
                },
                {
                    "type": "range",
                    "id": "heading_font_size_mobile",
                    "min": 14,
                    "max": 36,
                    "step": 1,
                    "unit": "px",
                    "label": "Heading Font Size (Mobile)",
                    "default": 24
                },
                {
                    "type": "range",
                    "id": "price_font_size_desktop",
                    "min": 12,
                    "max": 24,
                    "step": 1,
                    "unit": "px",
                    "label": "Price Font Size (Desktop)",
                    "default": 16
                },
                {
                    "type": "range",
                    "id": "price_font_size_mobile",
                    "min": 10,
                    "max": 20,
                    "step": 1,
                    "unit": "px",
                    "label": "Price Font Size (Mobile)",
                    "default": 14
                },
                {
                    "type": "url",
                    "id": "link",
                    "label": "Link"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Promo Category Grid",
            "blocks": [
                {
                    "type": "promo_card"
                },
                {
                    "type": "category_card"
                },
                {
                    "type": "category_card"
                },
                {
                    "type": "category_card"
                },
                {
                    "type": "category_card"
                }
            ]
        }
    ]
}
{% endschema %}
