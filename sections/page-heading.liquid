{%- comment -%}
------------------------------------------------------------------------------
  Section: Page Heading
  Displays the page title with customization options
------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign heading = page.title -%}
{%- assign custom_heading = section.settings.custom_heading -%}
{%- assign heading_size = section.settings.heading_size | default: 48 -%}
{%- assign heading_size_mobile = section.settings.heading_size_mobile | default: 32 -%}
{%- assign use_bristone_font = section.settings.use_bristone_font -%}
{%- assign text_align = section.settings.text_align -%}
{%- assign heading_color = section.settings.heading_color -%}
{%- assign bg_color = section.settings.bg_color -%}
{%- assign show_divider = section.settings.show_divider -%}
{%- assign divider_color = section.settings.divider_color -%}

{%- if custom_heading != blank -%}
  {%- assign heading = custom_heading -%}
{%- endif -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: {{ bg_color }};
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .page-heading-section-{{ section.id }} .page-heading__title {
    color: {{ heading_color }};
    text-align: {{ text_align }};
    font-size: {{ heading_size_mobile }}px;
    margin: 0;
    line-height: 1.2;
  }

  @media screen and (min-width: 768px) {
    .page-heading-section-{{ section.id }} .page-heading__title {
      font-size: {{ heading_size }}px;
    }
  }

  {%- if use_bristone_font -%}
    .page-heading-section-{{ section.id }} .page-heading__title {
      font-family: 'Bristone', var(--heading-font-family);
    }
  {%- endif -%}

  {%- if show_divider -%}
    .page-heading-section-{{ section.id }} .page-heading__divider {
      width: 80px;
      height: 2px;
      background-color: {{ divider_color }};
      margin-top: 20px;
      {% if text_align == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% elsif text_align == 'right' %}
        margin-left: auto;
      {% endif %}
    }
  {%- endif -%}
{%- endstyle -%}

<section class="page-heading-section page-heading-section-{{ section.id }}">
  <div class="page-width">
    {%- if heading != blank -%}
      <h1 class="page-heading__title">
        {{- heading -}}
      </h1>
    {%- endif -%}

    {%- if show_divider -%}
      <div class="page-heading__divider"></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Page Heading",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "custom_heading",
      "label": "Custom Heading",
      "info": "Leave blank to use the page title"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading Size (Desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading Size (Mobile)",
      "default": 32
    },
    {
      "type": "checkbox",
      "id": "use_bristone_font",
      "label": "Use Bristone font",
      "default": false
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Divider"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider line",
      "default": false
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Color",
      "default": "#2C2A28"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#2C2A28"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Page Heading"
    }
  ],
  "templates": ["page"]
}
{% endschema %}
