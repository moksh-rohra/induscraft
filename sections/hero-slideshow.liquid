{{ 'hero-slideshow.css' | asset_url | stylesheet_tag }}


{%- style -%}
  #shopify-section-{{ section.id }} .hero-slideshow {
    min-height: {{ section.settings.mobile_height }}vh;
    --min-height: {{ section.settings.mobile_height }}vh;
    --padding-horizontal: {{ section.settings.mobile_padding_horizontal }}px;
    --padding-vertical: {{ section.settings.mobile_padding_vertical }}px;
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .hero-slideshow {
      {%- if section.settings.full_screen -%}
        min-height: 100vh;
        --min-height: 100vh;
      {%- else -%}
        min-height: {{ section.settings.desktop_height }}vh;
        --min-height: {{ section.settings.desktop_height }}vh;
      {%- endif -%}
      --padding-horizontal: {{ section.settings.padding_horizontal }}px;
      --padding-vertical: {{ section.settings.padding_vertical }}px;
    }
  }
{%- endstyle -%}

{%- capture slider_settings -%}
  {
    "slidesPerView": 1,
    "grabCursor": true,
    "loop": true,
    "speed": {{ section.settings.speed | times: 1000 }},
    "effect": "slide",
    {%- if section.settings.autoplay -%}
    "autoplay": {
      "delay": {{ section.settings.autoplay_speed | times: 1000 }},
      "disableOnInteraction": false
    },
    {%- endif -%}
    {%- if section.settings.show_arrows -%}
    "navigation": {
      "nextEl": ".swiper-button-next",
      "prevEl": ".swiper-button-prev"
    },
    {%- endif -%}
    {%- if section.settings.show_pagination -%}
    "pagination": {
      "el": ".swiper-pagination",
      "clickable": true
    }
    {%- endif -%}
  }
{%- endcapture -%}

<section class="js-slideshow" id="{{ section.id }}">
<div class="hero-slideshow swiper js-slider">
  <div class="swiper-wrapper">
    {%- for block in section.blocks -%}
      <div class="swiper-slide block-{{ block.id }}" {{ block.shopify_attributes }}>
        {%- style -%}
            .block-{{ block.id }} {
                background-color: {{ block.settings.bg_color }};
                --overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
                --btn-1-bg: {{ block.settings.btn_1_bg_color }};
                --btn-1-bg-hover: {{ block.settings.btn_1_bg_color_hover }};
                --btn-1-text: {{ block.settings.btn_1_text_color }};
                --btn-1-text-hover: {{ block.settings.btn_1_text_color_hover }};
                --btn-1-border: {{ block.settings.btn_1_border_color }};
                --btn-1-border-hover: {{ block.settings.btn_1_border_color_hover }};
                --btn-2-bg: {{ block.settings.btn_2_bg_color }};
                --btn-2-bg-hover: {{ block.settings.btn_2_bg_color_hover }};
                --btn-2-text: {{ block.settings.btn_2_text_color }};
                --btn-2-text-hover: {{ block.settings.btn_2_text_color_hover }};
                --btn-2-border: {{ block.settings.btn_2_border_color }};
                --btn-2-border-hover: {{ block.settings.btn_2_border_color_hover }};
                --heading-font-size: {{ block.settings.heading_font_size_mobile }}px;
                --subheading-font-size: {{ block.settings.subheading_font_size_mobile }}px;
                --description-font-size: {{ block.settings.description_font_size_mobile }}px;
            }
            @media screen and (min-width: 768px) {
                .block-{{ block.id }} {
                    --heading-font-size: {{ block.settings.heading_font_size }}px;
                    --subheading-font-size: {{ block.settings.subheading_font_size }}px;
                    --description-font-size: {{ block.settings.description_font_size }}px;
                }
            }
            .block-{{ block.id }} .hero-slideshow__heading {
                color: {{ block.settings.text_color }};
                font-size: var(--heading-font-size);
            }
            .block-{{ block.id }} .hero-slideshow__subheading {
                color: {{ block.settings.text_color }};
                font-size: var(--subheading-font-size);
                display: flex;
                align-items: center;
                gap: 8px;
            }
            .block-{{ block.id }} .hero-slideshow__subheading-icon {
                width: 0.75em;
                height: 0.75em;
                min-width: 8px;
                min-height: 8px;
                border-radius: 2px;
                flex-shrink: 0;
                background-color: {{ block.settings.subheading_icon_color }};
            }
            .block-{{ block.id }} .hero-slideshow__description {
                color: {{ block.settings.text_color }};
                font-size: var(--description-font-size);
            }
        {%- endstyle -%}

        <div class="hero-slideshow__bg">
          {%- if block.settings.video_hosted != blank -%}
            {{ block.settings.video_hosted | video_tag: autoplay: false, loop: true, muted: true, controls: false, preload: 'none', image_size: 'master' }}
          {%- elsif block.settings.image != blank -%}
            {%- if forloop.first -%}
              {{ block.settings.image | image_url: width: 1920 | image_tag: loading: 'eager', fetchpriority: 'high', width: block.settings.image.width, height: block.settings.image.height, sizes: '100vw', widths: '375, 550, 750, 1100, 1500, 1920' }}
            {%- else -%}
              {{ block.settings.image | image_url: width: 1920 | image_tag: loading: 'lazy', width: block.settings.image.width, height: block.settings.image.height, sizes: '100vw', widths: '375, 550, 750, 1100, 1500, 1920' }}
            {%- endif -%}
          {%- endif -%}
        </div>

        <div class="hero-slideshow__overlay"></div>

        <div class="hero-slideshow__content-wrapper hero-slideshow__content-wrapper--{{ block.settings.content_alignment }} hero-slideshow__content-wrapper--v-{{ block.settings.content_vertical_alignment }}" style="padding: var(--padding-vertical) var(--padding-horizontal);">
          <div class="hero-slideshow__content hero-slideshow__content--{{ block.settings.text_alignment }}">
            {%- if block.settings.subheading != blank -%}
              <p class="hero-slideshow__subheading"><span class="hero-slideshow__subheading-icon"></span>{{ block.settings.subheading }}</p>
            {%- endif -%}

            {%- if block.settings.heading != blank -%}
              <h2 class="hero-slideshow__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}

            {%- if block.settings.description != blank -%}
              <div class="hero-slideshow__description rte">{{ block.settings.description }}</div>
            {%- endif -%}

            {%- if block.settings.btn_1_label != blank or block.settings.btn_2_label != blank -%}
              <div class="hero-slideshow__buttons">
                {%- if block.settings.btn_1_label != blank -%}
                  {%- if block.settings.btn_1_style == 'link' -%}
                    <a href="{{ block.settings.btn_1_link }}" class="button-link-new slideshow__slide-button hero-slideshow__btn-primary">
                        {{ block.settings.btn_1_label }}
                        <span class="button-link-new__icon-wrapper">
                            <span class="button-link-new__icon">
                                {% render 'icons-new', icon: 'arrow-right' %}
                            </span>
                        </span>
                    </a>
                  {%- else -%}
                    <a href="{{ block.settings.btn_1_link }}" class="button-new button--{{ block.settings.btn_1_style }} slideshow__slide-button hero-slideshow__btn-primary">
                        <span class="button__text">{{ block.settings.btn_1_label }}</span>
                    </a>
                  {%- endif -%}
                {%- endif -%}

                {%- if block.settings.btn_2_label != blank -%}
                   {%- if block.settings.btn_2_style == 'link' -%}
                    <a href="{{ block.settings.btn_2_link }}" class="button-link-new slideshow__slide-button slideshow__slide-button--second hero-slideshow__btn-secondary">
                        {{ block.settings.btn_2_label }}
                        <span class="button-link-new__icon-wrapper">
                            <span class="button-link-new__icon">
                                {% render 'icons-new', icon: 'arrow-right' %}
                            </span>
                        </span>
                    </a>
                   {%- else -%}
                    <a href="{{ block.settings.btn_2_link }}" class="button-new button--{{ block.settings.btn_2_style }} slideshow__slide-button slideshow__slide-button--second hero-slideshow__btn-secondary">
                        <span class="button__text">{{ block.settings.btn_2_label }}</span>
                    </a>
                   {%- endif -%}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.show_arrows -%}
    <div class="swiper-button-prev">{% render 'icons-big', icon: 'round-arrow' %}</div>
    <div class="swiper-button-next">{% render 'icons-big', icon: 'round-arrow' %}</div>
  {%- endif -%}

  {%- if section.settings.show_pagination -%}
    <div class="swiper-pagination"></div>
  {%- endif -%}

  <script class="js-slider-settings" type="application/json">
    {{- slider_settings -}}
  </script>
</div>

<script src="{{- 'component-swiper-modules.build.min.js' | asset_url -}}" defer></script>
<script src="{{- 'section-slideshow.build.min.js' | asset_url -}}" defer></script>

<script>
  // Hero slideshow: play video only on active slide
  document.addEventListener('DOMContentLoaded', function() {
    var sectionEl = document.getElementById('{{ section.id }}');
    if (!sectionEl) return;
    var swiperEl = sectionEl.querySelector('.swiper');
    if (!swiperEl) return;

    function handleSlideVideos(swiper) {
      // Pause all videos
      swiperEl.querySelectorAll('video').forEach(function(v) { v.pause(); });
      // Play video in active slide
      var activeSlide = swiper.slides[swiper.activeIndex];
      if (activeSlide) {
        var video = activeSlide.querySelector('video');
        if (video) {
          video.preload = 'auto';
          video.play().catch(function() {});
        }
      }
    }

    // Wait for Swiper to initialize (it's deferred)
    var checkSwiper = setInterval(function() {
      if (swiperEl.swiper) {
        clearInterval(checkSwiper);
        var swiper = swiperEl.swiper;
        // Play first slide video on init
        handleSlideVideos(swiper);
        // Handle slide changes
        swiper.on('slideChangeTransitionEnd', function() {
          handleSlideVideos(swiper);
        });
      }
    }, 100);
    // Stop checking after 10s
    setTimeout(function() { clearInterval(checkSwiper); }, 10000);
  });
</script>
</section>

{% schema %}
