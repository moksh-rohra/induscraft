{% comment %}
------------------------------------------------------------------------------
  Section: Tab Product Showcase
  A section with left-side tabs and right-side product/image display.
------------------------------------------------------------------------------
{% endcomment %}

{{ 'tab-product-showcase.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --tps-bg-color: {{ section.settings.bg_color }};
    --tps-text-color: {{ section.settings.text_color }};
    --tps-accent-color: {{ section.settings.accent_color }};
    --tps-tab-inactive-color: {{ section.settings.tab_inactive_color }};
    --tps-card-bg-color: {{ section.settings.card_bg_color }};
    --tps-subheading-size: {{ section.settings.subheading_font_size }}px;
    --tps-subheading-size-mobile: {{ section.settings.subheading_font_size_mobile }}px;
    --tps-heading-size: {{ section.settings.heading_font_size }}px;
    --tps-heading-size-mobile: {{ section.settings.heading_font_size_mobile }}px;
    --tps-desc-size: {{ section.settings.description_font_size }}px;
    --tps-desc-size-mobile: {{ section.settings.description_font_size_mobile }}px;
    --tps-tab-size: {{ section.settings.tab_font_size }}px;
    --tps-tab-size: {{ section.settings.tab_font_size }}px;
    --tps-tab-size-mobile: {{ section.settings.tab_font_size_mobile }}px;
    --tps-section-radius: {{ section.settings.section_border_radius }}px;
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .tabbed-product-showcase__container {
    padding-top: {{ section.settings.inner_padding_v_mobile }}px;
    padding-bottom: {{ section.settings.inner_padding_v_mobile }}px;
    padding-left: {{ section.settings.inner_padding_h_mobile }}px;
    padding-right: {{ section.settings.inner_padding_h_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .tabbed-product-showcase__container {
      padding-top: {{ section.settings.inner_padding_v_desktop }}px;
      padding-bottom: {{ section.settings.inner_padding_v_desktop }}px;
      padding-left: {{ section.settings.inner_padding_h_desktop }}px;
      padding-right: {{ section.settings.inner_padding_h_desktop }}px;
    }
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .tabbed-product-showcase__card {
      max-width: {{ section.settings.card_max_width }}px;
    }
  }

{%- endstyle -%}

<section class="tabbed-product-showcase" data-section-id="{{ section.id }}">
  <div class="tabbed-product-showcase__container">
    {%- if section.settings.subheading != blank -%}
      <div class="tabbed-product-showcase__subheading">
        <span class="tabbed-product-showcase__subheading-icon" style="background-color: {{ section.settings.accent_color }};"></span>
        {{ section.settings.subheading }}
      </div>
    {%- endif -%}
    
    <div class="tabbed-product-showcase__title-row">
      {%- if section.settings.heading != blank -%}
        <h2 class="tabbed-product-showcase__section-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.section_description != blank -%}
        <div class="tabbed-product-showcase__section-desc">{{ section.settings.section_description }}</div>
      {%- endif -%}
    </div>

    <div class="tabbed-product-showcase__content">
      {%- comment -%} Left Side - Tabs {%- endcomment -%}
      <div class="tabbed-product-showcase__tabs">
        {%- for block in section.blocks -%}
          <button
            type="button"
            class="tabbed-product-showcase__tab {% if forloop.first %}is-active{% endif %}"
            data-tab-index="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            <span class="tabbed-product-showcase__tab-text">{{ block.settings.tab_title }}</span>
            <span class="tabbed-product-showcase__tab-arrow">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
              </svg>
            </span>
          </button>
        {%- endfor -%}
      </div>

      {%- comment -%} Right Side - Content Panels {%- endcomment -%}
      <div class="tabbed-product-showcase__panels">
        {%- for block in section.blocks -%}
          <div class="tabbed-product-showcase__panel {% if forloop.first %}is-active{% endif %}" data-panel-index="{{ forloop.index0 }}">
            <div class="tabbed-product-showcase__card {% if block.settings.product != blank %}tabbed-product-showcase__card--product{% endif %}">
              {%- if block.settings.product != blank -%}
                {%- assign card_product = block.settings.product -%}
                <div class="tabbed-product-showcase__product-card">
                  <a href="{{ card_product.url }}" class="tabbed-product-showcase__product-link">
                    <div class="tabbed-product-showcase__product-image-wrapper">
                      {%- if card_product.featured_image != blank -%}
                        <img
                          src="{{ card_product.featured_image | image_url: width: 400, height: 450, crop: 'center' }}"
                          alt="{{ card_product.featured_image.alt | escape }}"
                          width="400"
                          height="450"
                          loading="lazy"
                          class="tabbed-product-showcase__product-image"
                        >
                      {%- else -%}
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </div>
                  </a>
                  
                  <div class="tabbed-product-showcase__product-info">
                    <h3 class="tabbed-product-showcase__product-title">
                      <a href="{{ card_product.url }}">{{ card_product.title }}</a>
                    </h3>
                    
                    <div class="tabbed-product-showcase__product-price">
                      <span class="price-item price-item--regular">
                        {{ card_product.price | money }}
                      </span>
                      {%- if card_product.compare_at_price > card_product.price -%}
                        <s class="price-item price-item--sale">
                          {{ card_product.compare_at_price | money }}
                        </s>
                      {%- endif -%}
                    </div>

                    <div class="tabbed-product-showcase__product-actions">
                      {%- form 'product', card_product, class: 'product-form', novalidate: 'novalidate' -%}
                        <input type="hidden" name="id" value="{{ card_product.selected_or_first_available_variant.id }}">
                        <div class="product-form__buttons">
                          <button
                            type="submit"
                            name="add"
                            class="tabbed-product-showcase__btn tps-btn"
                            style="
                              --btn-bg: {{ block.settings.atc_bg_color }};
                              --btn-text: {{ block.settings.atc_text_color }};
                              --btn-border: {{ block.settings.atc_border_color }};
                              --btn-hover-bg: {{ block.settings.atc_hover_bg_color }};
                              --btn-hover-text: {{ block.settings.atc_hover_text_color }};
                              --btn-hover-border: {{ block.settings.atc_hover_border_color }};
                              --btn-radius: {{ block.settings.btn_border_radius }}px;
                              --btn-border-width: {{ block.settings.btn_border_width }}px;
                              --btn-font-size: {{ block.settings.btn_font_size }}px;
                              --btn-padding-y: {{ block.settings.btn_padding_y }}px;
                              --btn-padding-x: {{ block.settings.btn_padding_x }}px;
                            "
                            {% if card_product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                          >
                            <span>
                              {%- if card_product.selected_or_first_available_variant.available -%}
                                Add to cart
                              {%- else -%}
                                Sold out
                              {%- endif -%}
                            </span>
                          </button>
                          
                          {%- if card_product.selected_or_first_available_variant.available -%}
                             <a href="{{ routes.cart_url }}/{{ card_product.selected_or_first_available_variant.id }}:1" 
                                class="tabbed-product-showcase__btn tps-btn"
                                style="
                                  --btn-bg: {{ block.settings.bin_bg_color }};
                                  --btn-text: {{ block.settings.bin_text_color }};
                                  --btn-border: {{ block.settings.bin_border_color }};
                                  --btn-hover-bg: {{ block.settings.bin_hover_bg_color }};
                                  --btn-hover-text: {{ block.settings.bin_hover_text_color }};
                                  --btn-hover-border: {{ block.settings.bin_hover_border_color }};
                                  --btn-radius: {{ block.settings.btn_border_radius }}px;
                                  --btn-border-width: {{ block.settings.btn_border_width }}px;
                                  --btn-font-size: {{ block.settings.btn_font_size }}px;
                                  --btn-padding-y: {{ block.settings.btn_padding_y }}px;
                                  --btn-padding-x: {{ block.settings.btn_padding_x }}px;
                                "
                             >
                              Buy it now
                            </a>
                          {%- endif -%}
                        </div>
                      {%- endform -%}
                    </div>
                  </div>
                </div>
              {%- elsif block.settings.custom_image != blank -%}
                <div class="tabbed-product-showcase__card-image">
                  <img
                    src="{{ block.settings.custom_image | image_url: width: 600 }}"
                    alt="{{ block.settings.custom_image_alt | default: block.settings.tab_title | escape }}"
                    width="600"
                    height="{{ 600 | divided_by: block.settings.custom_image.aspect_ratio | round }}"
                    loading="lazy"
                  >
                </div>
              {%- else -%}
                <div class="tabbed-product-showcase__card-image tabbed-product-showcase__card-placeholder">
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>

            {%- unless block.settings.product != blank -%}
              {%- if block.settings.custom_heading != blank -%}
                <h3 class="tabbed-product-showcase__heading">{{ block.settings.custom_heading }}</h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="tabbed-product-showcase__description">{{ block.settings.description }}</p>
              {%- endif -%}
            {%- endunless -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    const tabs = section.querySelectorAll('.tabbed-product-showcase__tab');
    const panels = section.querySelectorAll('.tabbed-product-showcase__panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const index = this.dataset.tabIndex;

        // Remove active class from all tabs and panels
        tabs.forEach(t => t.classList.remove('is-active'));
        panels.forEach(p => p.classList.remove('is-active'));

        // Add active class to clicked tab and corresponding panel
        this.classList.add('is-active');
        section.querySelector(`[data-panel-index="${index}"]`).classList.add('is-active');
      });
    });
  });
</script>

