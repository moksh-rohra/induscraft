{%- comment -%}
  Custom Footer Section
  =====================
  A minimal, high-impact footer with a massive text logo, 
  grid-based contact/menu layout, and social icons.
{%- endcomment -%}

{{ 'custom-footer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #custom-footer-{{ section.id }} {
    --footer-bg-color: {{ section.settings.background_color }};
    --footer-text-color: {{ section.settings.text_color }};
    --logo-text-color: {{ section.settings.logo_text_color | default: section.settings.text_color }};
    
    --intro-heading-size: {{ section.settings.intro_heading_size }}px;
    --intro-description-size: {{ section.settings.intro_description_size }}px;
    
    --contact-heading-size: {{ section.settings.contact_heading_size }}px;
    --contact-email-size: {{ section.settings.contact_email_size }}px;
    --contact-phone-size: {{ section.settings.contact_phone_size }}px;
    --contact-address-size: {{ section.settings.contact_address_size }}px;
    
    --footer-padding-top: {{ section.settings.padding_top }}px;
    --footer-padding-bottom: {{ section.settings.padding_bottom }}px;
    
    --logo-image-width: {{ section.settings.logo_image_width }}px;
    
    /* Logo font size - conditional based on full_width_logo toggle */
    {%- if section.settings.full_width_logo -%}
      --logo-font-size-desktop: 11.4vw;
      --logo-font-size-mobile: 10vw;
    {%- else -%}
      --logo-font-size-desktop: {{ section.settings.logo_font_size_desktop }}px;
      --logo-font-size-mobile: {{ section.settings.logo_font_size_mobile }}px;
    {%- endif -%}
    
    /* Font overrides if needed */
    --font-body-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
  }

  @font-face {
    font-family: 'Bristone Reg';
    src: url({{ 'Bristone Reg.otf' | asset_url }}) format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  #custom-footer-{{ section.id }} .custom-footer__big-logo {
    font-family: 'Bristone Reg', serif;
  }
{%- endstyle -%}

<footer id="custom-footer-{{ section.id }}" class="custom-footer" data-section-id="{{ section.id }}">
  <div class="custom-footer__container">
  

    
    <!-- TOP ROW: Contact & Menus -->
    <div class="custom-footer__top">
      
      <!-- Contact Info (Left) -->
      <div class="custom-footer__contact">
        <!-- Intro Section -->
        {%- if section.settings.intro_heading != blank or section.settings.intro_subheading != blank or section.settings.intro_description != blank -%}
          <div class="custom-footer__intro">
            {%- if section.settings.intro_subheading != blank -%}
              <span class="custom-footer__intro-subheading">{{ section.settings.intro_subheading }}</span>
            {%- endif -%}
            {%- if section.settings.intro_heading != blank -%}
              <h3 class="custom-footer__intro-heading">{{ section.settings.intro_heading }}</h3>
            {%- endif -%}
            {%- if section.settings.intro_description != blank -%}
              <div class="custom-footer__intro-description">{{ section.settings.intro_description }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.contact_heading != blank -%}
            <span class="custom-footer__heading">{{ section.settings.contact_heading }}</span>
        {%- endif -%}

        {%- if section.settings.contact_email != blank -%}
             <a href="mailto:{{ section.settings.contact_email }}" class="custom-footer__email">{{ section.settings.contact_email }}</a>
        {%- endif -%}

        {%- if section.settings.contact_phone != blank -%}
             <a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}" class="custom-footer__phone">{{ section.settings.contact_phone }}</a>
        {%- endif -%}

        {%- if section.settings.contact_address != blank -%}
             <div class="custom-footer__address">{{ section.settings.contact_address | newline_to_br }}</div>
        {%- endif -%}
      </div>

      <!-- Links Columns (Right) -->
      <div class="custom-footer__links-wrapper">
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_list' -%}
            <div class="custom-footer__menu-column">
              {%- if block.settings.heading != blank -%}
                 <h4 class="custom-footer__heading">{{ block.settings.heading }}</h4>
              {%- endif -%}
              
              {%- if block.settings.menu != blank -%}
                <ul class="custom-footer__menu-list">
                  {%- for link in block.settings.menu.links -%}
                    <li class="custom-footer__menu-item">
                      <a href="{{ link.url }}" class="custom-footer__menu-link">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>


    <!-- MIDDLE ROW: Big Logo -->
    <div class="custom-footer__middle">
        {%- if section.settings.logo_image != blank -%}
            {{ section.settings.logo_image | image_url: width: 1400 | image_tag: class: 'custom-footer__logo-image', loading: 'lazy' }}
        {%- else -%}
            <h2 class="custom-footer__big-logo">{{ section.settings.logo_text | default: 'Induscraft.' }}</h2>
        {%- endif -%}
    </div>


    <!-- BOTTOM ROW: Copyright & Socials -->
    <div class="custom-footer__bottom">
      
      <!-- Copyright & Credits -->
      <div class="custom-footer__copyright-wrapper">
        <p class="custom-footer__copyright">
          &copy; Copyright - {{ shop.name }} | {{ 'now' | date: "%Y" }}
          {%- if section.settings.show_credits -%}
             <span class="copyright-divider">|</span> Designed by <a href="#" style="text-decoration: underline; color: inherit;">Anish</a>
             <span class="copyright-divider">|</span> Powered by <a href="#" style="text-decoration: underline; color: inherit;">Shopify</a>
          {%- endif -%}
        </p>
      </div>

      <!-- Social Icons -->
      {%- if section.settings.show_social -%}
        <div class="custom-footer__socials">
          {%- if settings.social_instagram_link != blank -%}
             <a href="{{ settings.social_instagram_link }}" class="social-icon-circle" aria-label="Instagram">
               {% render 'icons-new', icon: 'instagram' %}
             </a>
          {%- endif -%}
          {%- if settings.social_facebook_link != blank -%}
             <a href="{{ settings.social_facebook_link }}" class="social-icon-circle" aria-label="Facebook">
               {% render 'icons-new', icon: 'facebook' %}
             </a>
          {%- endif -%}
           {%- if settings.social_twitter_link != blank -%}
             <a href="{{ settings.social_twitter_link }}" class="social-icon-circle" aria-label="Twitter">
               {% render 'icons-new', icon: 'twitter' %}
             </a>
          {%- endif -%}
           {%- if settings.social_linkedin_link != blank -%}
             <a href="{{ settings.social_linkedin_link }}" class="social-icon-circle" aria-label="LinkedIn">
               {% render 'icons-new', icon: 'linkedin' %}
             </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</footer>

{%- if section.settings.full_width_logo -%}
<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const logoEl = document.querySelector('#custom-footer-' + sectionId + ' .custom-footer__big-logo');
    const container = document.querySelector('#custom-footer-' + sectionId + ' .custom-footer__middle');
    
    if (!logoEl || !container) return;
    
    function fitText() {
      // Reset font-size to measure natural width
      logoEl.style.fontSize = '100px';
      
      const containerWidth = container.clientWidth;
      const textWidth = logoEl.scrollWidth;
      
      // Calculate the ratio and apply new font-size
      const ratio = containerWidth / textWidth;
      const newSize = Math.floor(100 * ratio);
      
      logoEl.style.fontSize = newSize + 'px';
    }
    
    // Run on load
    fitText();
    
    // Run on resize (debounced for performance)
    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(fitText, 100);
    });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Custom Footer",
  "tag": "footer",
  "class": "section-custom-footer",
  "enabled_on": {
    "groups": ["footer", "header"]
