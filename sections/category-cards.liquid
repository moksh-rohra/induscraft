{{ 'section-category-cards.css' | asset_url | stylesheet_tag }}

{%- assign bg_color = section.settings.background_color | default: '#e8eaf0' -%}
{%- assign heading_color = section.settings.heading_color | default: '#1a1a1a' -%}
{%- assign label_color = section.settings.label_color | default: '#1a1a1a' -%}

<section class="category-cards-section" style="--cc-bg: {{ bg_color }}; --cc-heading: {{ heading_color }}; --cc-label: {{ label_color }};">
  <div class="category-cards__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="category-cards__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="category-cards__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          <a href="{{ block.settings.link | default: '#' }}" class="category-card" {{ block.shopify_attributes }}>
            <div class="category-card__image">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.label | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'category-card__placeholder' }}
              {%- endif -%}
            </div>
            {%- if block.settings.label != blank -%}
              <div class="category-card__label">{{ block.settings.label }}</div>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Cards",
  "tag": "section",
  "class": "category-cards-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Available in-"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#e8eaf0"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#1a1a1a"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Card label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Cards",
      "blocks": [
        { "type": "card", "settings": { "label": "Hydraulic Lift Storage Bed" } },
        { "type": "card", "settings": { "label": "Drawer Storage Bed" } },
        { "type": "card", "settings": { "label": "Box Storage Bed" } }
      ]
    }
  ]
}
{% endschema %}
