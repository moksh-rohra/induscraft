          "id": "review_image",
          "label": "Review Image 1"
        },
        {
          "type": "image_picker",
          "id": "review_image_2",
          "label": "Review Image 2"
        },
        {
          "type": "image_picker",
          "id": "review_image_3",
          "label": "Review Image 3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Google Reviews Marquee",
      "blocks": [
        {
          "type": "review",
          "settings": { "row_position": "top" }
        },
        {
          "type": "review",
          "settings": { "row_position": "top" }
        },
        {
          "type": "review",
          "settings": { "row_position": "bottom" }
        },
           {
          "type": "review",
          "settings": { "row_position": "bottom" }
        }
      ]
    }
  ]
}
{% endschema %}
