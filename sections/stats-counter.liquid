
{{ 'section-stats-counter.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .section-{{ section.id }}-padding .sc-label {
    color: {{ section.settings.label_color }};
    font-size: {{ section.settings.label_size_mobile }}px;
  }

  .section-{{ section.id }}-padding .sc-label-icon {
    background-color: {{ section.settings.label_icon_color }};
    width: {{ section.settings.label_size_mobile | times: 0.8 }}px;
    height: {{ section.settings.label_size_mobile | times: 0.8 }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding .sc-label {
      font-size: {{ section.settings.label_size }}px;
    }

    .section-{{ section.id }}-padding .sc-label-icon {
      width: {{ section.settings.label_size | times: 0.8 }}px;
      height: {{ section.settings.label_size | times: 0.8 }}px;
    }
  }

  .section-{{ section.id }}-padding .sc-heading {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding .sc-heading {
      font-size: {{ section.settings.heading_size }}px;
    }
  }

  .section-{{ section.id }}-padding .sc-description {
    color: {{ section.settings.text_color }};
  }

  .section-{{ section.id }}-padding .sc-card {
    background-color: {{ section.settings.card_bg_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
  }

  .section-{{ section.id }}-padding .sc-card-label {
    color: {{ section.settings.card_label_color }};
  }

  .section-{{ section.id }}-padding .sc-card-dot {
    background-color: {{ section.settings.card_dot_color }};
  }

  .section-{{ section.id }}-padding .sc-card-number {
    color: {{ section.settings.number_color }};
    font-size: {{ section.settings.number_size_mobile }}px;
    font-family: 'Bristone', var(--heading-font-family);
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding .sc-card-number {
      font-size: {{ section.settings.number_size }}px;
    }
  }

  .section-{{ section.id }}-padding .sc-card-suffix {
    color: {{ section.settings.suffix_color }};
  }
{%- endstyle -%}

<div class="stats-counter-section section-{{ section.id }}-padding" data-section-id="{{ section.id }}">
  <div class="sc-container page-width">
    <!-- Header Row -->
    <div class="sc-header">
      <div class="sc-header-left">
        {%- if section.settings.label != blank -%}
          <div class="sc-label-wrapper">
            <span class="sc-label-icon"></span>
            <p class="sc-label">{{ section.settings.label | escape }}</p>
          </div>
        {%- endif -%}
      </div>
      <div class="sc-header-right">
        {%- if section.settings.heading != blank -%}
          <h2 class="sc-heading sc-animate-text">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="sc-description sc-animate-text">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    </div>

    <!-- Stats Cards -->
    {%- if section.blocks.size > 0 -%}
      <div class="sc-cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'sc_stat_card' -%}
            <div class="sc-card" {{ block.shopify_attributes }}>
              <div class="sc-card-header">
                <span class="sc-card-dot"></span>
                <span class="sc-card-label" style="font-size: {{ block.settings.label_size }}px;">{{ block.settings.label | escape }}</span>
              </div>
              <div class="sc-card-value">
                <span 
                  class="sc-card-number" 
                  data-duration="{{ section.settings.animation_duration }}"
                >{{ block.settings.number }}</span>
                {%- if block.settings.suffix != blank -%}
                  <span class="sc-card-suffix">{{ block.settings.suffix | escape }}</span>
                {%- endif -%}
              </div>
              {%- if block.settings.description != blank -%}
                <p class="sc-card-description" style="font-size: {{ block.settings.description_size }}px; color: {{ block.settings.description_color }};">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    // Wait for GSAP to load
    const checkGSAP = setInterval(function() {
      if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
        clearInterval(checkGSAP);
        initAnimations();
      }
    }, 100);

    function initAnimations() {
      gsap.registerPlugin(ScrollTrigger);

      // Staggered text animation for heading and description
      const textElements = section.querySelectorAll('.sc-animate-text');
      if (textElements.length > 0) {
        gsap.set(textElements, { opacity: 0, y: 40 });
        
        gsap.to(textElements, {
          opacity: 1,
          y: 0,
          duration: 0.8,
          stagger: 0.2,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: section,
            start: 'top 80%',
            toggleActions: 'play none none none'
          }
        });
      }

      // Counter animation for numbers - Rotating counter with guaranteed movement
      const numberElements = section.querySelectorAll('.sc-card-number');
      numberElements.forEach(function(el) {
        const originalText = el.textContent.trim();
        const duration = parseFloat(el.dataset.duration) || 2.5;
        
        // Clear and rebuild
        el.innerHTML = '';
        el.classList.add('sc-slot-container');
        
        let digitIndex = 0;
        
        // Create digit slots for each character
        originalText.split('').forEach(function(char) {
          const slot = document.createElement('span');
          slot.className = 'sc-digit-slot';
          
          // If it's not a number (like comma), display statically
          if (isNaN(parseInt(char))) {
            slot.textContent = char;
            slot.classList.add('sc-static-char');
            el.appendChild(slot);
            return;
          }
          
          const track = document.createElement('span');
          track.className = 'sc-digit-track';
          
          // Create 3 sets of digits 0-9 (30 total) for guaranteed full rotation
          for (let set = 0; set < 3; set++) {
            for (let i = 0; i <= 9; i++) {
              const digitEl = document.createElement('span');
              digitEl.className = 'sc-digit';
              digitEl.textContent = i;
              track.appendChild(digitEl);
            }
          }
          
          const targetDigit = parseInt(char);
          const isEven = digitIndex % 2 === 0;
          
          // Store animation data
          track.dataset.target = targetDigit;
          track.dataset.direction = isEven ? 'up' : 'down';
          track.dataset.delay = (digitIndex * 0.12).toString();
          
          slot.appendChild(track);
          el.appendChild(slot);
          
          digitIndex++;
        });

        // Animate on scroll
        ScrollTrigger.create({
          trigger: el,
          start: 'top 85%',
          onEnter: function() {
            const tracks = el.querySelectorAll('.sc-digit-track');
            
            tracks.forEach(function(track) {
              const targetDigit = parseInt(track.dataset.target);
              const direction = track.dataset.direction;
              const delay = parseFloat(track.dataset.delay);
              
              // Target position: land on middle set (positions 10-19)
              // This ensures we always have room to animate from either direction
              const targetPosition = 10 + targetDigit;
              const targetY = -targetPosition; // in em units
              
              // Start position: always 10 positions away (one full rotation)
              let startPosition;
              if (direction === 'up') {
                // Start from first set, roll UP through digits
                startPosition = targetDigit; // First set (0-9)
              } else {
                // Start from third set, roll DOWN through digits  
                startPosition = 20 + targetDigit; // Third set (20-29)
              }
              const startY = -startPosition;
              
              gsap.fromTo(track, 
                { y: startY + 'em' },
                {
                  y: targetY + 'em',
                  duration: duration,
                  delay: delay,
                  ease: 'power3.inOut'
                }
              );
            });
          },
          once: true
        });
      });

      // Card entrance animation
      const cards = section.querySelectorAll('.sc-card');
      if (cards.length > 0) {
        gsap.set(cards, { opacity: 0, y: 30 });
        
        gsap.to(cards, {
          opacity: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.15,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: section.querySelector('.sc-cards'),
            start: 'top 85%',
            toggleActions: 'play none none none'
          }
        });
      }
    }
  });
</script>

