{{ 'section-text-marquee.css' | asset_url | stylesheet_tag }}

<style>
  @font-face {
    font-family: 'Bristone';
    src: url({{ 'Bristone Reg.otf' | asset_url }}) format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  .text-marquee-section {
    --tm-bg-color: {{ section.settings.background_color }};
    --tm-text-color: {{ section.settings.text_color }};
    --tm-font-size: {{ section.settings.font_size }}px;
    --tm-font-size-mobile: {{ section.settings.font_size_mobile }}px;
    --tm-font-weight: {{ section.settings.font_weight }};
    --tm-letter-spacing: {{ section.settings.letter_spacing | divided_by: 100.0 }}em;
    --tm-speed: {{ section.settings.animation_speed }}s;
    --tm-padding-top: {{ section.settings.padding_top }}px;
    --tm-padding-bottom: {{ section.settings.padding_bottom }}px;
    --tm-gap: {{ section.settings.item_gap }}px;

    {%- if section.settings.enable_top_border -%}
    border-top: {{ section.settings.top_border_thickness }}px solid {{ section.settings.top_border_color }};
    {%- endif -%}
    {%- if section.settings.enable_bottom_border -%}
    border-bottom: {{ section.settings.bottom_border_thickness }}px solid {{ section.settings.bottom_border_color }};
    {%- endif -%}
  }
</style>

<section class="text-marquee-section" data-section-id="{{ section.id }}">
  <div class="tm-container">
    <div class="tm-track {% if section.settings.pause_on_hover %}tm-pause-on-hover{% endif %} {% if section.settings.direction == 'right' %}tm-reverse{% endif %}">
      {%- for i in (1..2) -%}
        <div class="tm-content">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'text_item' -%}
                <div class="tm-item tm-text-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}" class="tm-text {% if block.settings.use_bristone_font %}tm-bristone{% endif %}">
                      {{ block.settings.text | escape }}
                    </a>
                  {%- else -%}
                    <span class="tm-text {% if block.settings.use_bristone_font %}tm-bristone{% endif %}">
                      {{ block.settings.text | escape }}
                    </span>
                  {%- endif -%}
                </div>
              {%- when 'icon_item' -%}
                <div class="tm-item tm-icon-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon_image != blank -%}
                    <img 
                      src="{{ block.settings.icon_image | image_url: width: 100 }}" 
                      alt="Icon" 
                      class="tm-icon-img"
                      width="{{ block.settings.icon_size }}"
                      height="{{ block.settings.icon_size }}"
                      loading="lazy"
                      style="filter: hue-rotate({{ block.settings.image_hue }}deg);"
                    >
                  {%- else -%}
                    <svg class="tm-icon-svg" width="{{ block.settings.icon_size }}" height="{{ block.settings.icon_size }}" viewBox="0 0 24 24" fill="{{ block.settings.icon_color }}">
                      <path d="M12 0L14.59 8.41L23 11L14.59 13.59L12 22L9.41 13.59L1 11L9.41 8.41L12 0Z"/>
                    </svg>
                  {%- endif -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Scrolling Text Marquee",
  "tag": "section",
  "class": "section-text-marquee",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 16,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Font Size (Desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 14,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Font Size (Mobile)",
      "default": 24
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": -5,
      "max": 30,
      "step": 1,
      "label": "Letter Spacing",
      "default": 2
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "animation_speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Animation Duration",
      "default": 20,
      "info": "Lower = faster"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll Direction",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on Hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "checkbox",
      "id": "enable_top_border",
      "label": "Enable Top Border",
      "default": false
    },
    {
      "type": "color",
      "id": "top_border_color",
      "label": "Top Border Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "top_border_thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Top Border Thickness",
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "enable_bottom_border",
      "label": "Enable Bottom Border",
      "default": false
    },
    {
      "type": "color",
      "id": "bottom_border_color",
      "label": "Bottom Border Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "bottom_border_thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Bottom Border Thickness",
      "default": 1
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "item_gap",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Gap Between Items",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "text_item",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "MARQUEE TEXT"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Optional)"
        },
        {
          "type": "checkbox",
          "id": "use_bristone_font",
          "label": "Use Bristone Font",
          "default": false
        }
      ]
    },
    {
      "type": "icon_item",
      "name": "Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom Icon Image",
          "info": "Leave blank to use default star"
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Icon Color",
          "default": "#C8FF00",
          "info": "Only applies to default star icon"
        },
        {
          "type": "range",
          "id": "icon_size",
          "min": 12,
          "max": 60,
          "step": 2,
          "unit": "px",
          "label": "Icon Size",
          "default": 24
        },
        {
          "type": "range",
          "id": "image_hue",
          "min": 0,
          "max": 360,
          "step": 10,
          "unit": "deg",
          "label": "Image Hue Rotation",
          "default": 0,
          "info": "Adjusts the color of the uploaded icon image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Text Marquee",
      "blocks": [
        {
          "type": "icon_item"
        },
        {
          "type": "text_item",
          "settings": {
            "text": "COMMERCIAL INTERIORS"
          }
        },
        {
          "type": "icon_item"
        },
        {
          "type": "text_item",
          "settings": {
            "text": "HOME RENOVATION"
          }
        },
        {
          "type": "icon_item"
        },
        {
          "type": "text_item",
          "settings": {
            "text": "OFFICE SPACES"
          }
        }
      ]
    }
  ]
}
{% endschema %}
