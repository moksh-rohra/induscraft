{{ 'section-product-slider.css' | asset_url | stylesheet_tag }}

{%- assign bg_color = section.settings.background_color | default: '#ffffff' -%}

<section
  class="product-slider-section"
  style="--ps-bg: {{ bg_color }};"
  data-product-slider
>
  <div class="product-slider__track" data-slider-track>
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        <div class="product-slider__slide{% if forloop.first %} is-active{% endif %}" data-slide-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <div class="product-slider__image">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.heading | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'product-slider__placeholder' }}
            {%- endif -%}
          </div>
          <div class="product-slider__content">
            {%- if block.settings.heading != blank -%}
              <h2 class="product-slider__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="product-slider__text">{{ block.settings.text }}</div>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link | default: '#' }}" class="button-new button--primary">
                {{ block.settings.button_label }}
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="product-slider__nav">
      <button class="product-slider__arrow product-slider__arrow--prev" data-slider-prev aria-label="Previous slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <span class="product-slider__counter">
        <span data-slider-current>1</span>/<span data-slider-total>{{ section.blocks.size }}</span>
      </span>
      <button class="product-slider__arrow product-slider__arrow--next" data-slider-next aria-label="Next slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  {%- endif -%}
</section>

<script>
  (function() {
    var sections = document.querySelectorAll('[data-product-slider]');
    sections.forEach(function(section) {
      var slides = section.querySelectorAll('[data-slide-index]');
      var prevBtn = section.querySelector('[data-slider-prev]');
      var nextBtn = section.querySelector('[data-slider-next]');
      var currentEl = section.querySelector('[data-slider-current]');
      var currentIndex = 0;
      var total = slides.length;

      function goTo(index) {
        if (index < 0) index = total - 1;
        if (index >= total) index = 0;
        slides.forEach(function(s) { s.classList.remove('is-active'); });
        slides[index].classList.add('is-active');
        currentIndex = index;
        if (currentEl) currentEl.textContent = currentIndex + 1;
      }

      if (prevBtn) prevBtn.addEventListener('click', function() { goTo(currentIndex - 1); });
      if (nextBtn) nextBtn.addEventListener('click', function() { goTo(currentIndex + 1); });
    });
  })();
</script>

{% schema %}
{
  "name": "Product Slider",
  "tag": "section",
  "class": "product-slider-wrapper",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Slide heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Add your slide description here.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Slider",
      "blocks": [
        { "type": "slide", "settings": { "heading": "Hydraulic Storage Beds" } },
        { "type": "slide", "settings": { "heading": "Drawer Storage Beds" } },
        { "type": "slide", "settings": { "heading": "Box Storage Beds" } }
      ]
    }
  ]
}
{% endschema %}
