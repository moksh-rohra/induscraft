{%- comment -%}
  Parallax Video Section
  ======================
  A versatile hero section supporting:
  - Background Video (Shopify hosted) or Image
  - Parallax Effects: Mixed (GSAP Scrub), Fixed (CSS), or None
  - Overlay Content: Tagline, Heading, Description, Button
{%- endcomment -%}

{{ 'parallax-video.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #parallax-video-{{ section.id }} {
    --overlay-color: {{ section.settings.overlay_color }};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --margin-top-mobile: {{ section.settings.margin_top_mobile }}px;
    --margin-bottom-mobile: {{ section.settings.margin_bottom_mobile }}px;
    --tagline-size-mobile: {{ section.settings.tagline_size_mobile }}px;
    --heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --description-size-mobile: {{ section.settings.description_size_mobile }}px;
    height: {{ section.settings.height_mobile }}px;
  }
  @media screen and (min-width: 768px) {
    #parallax-video-{{ section.id }} {
      height: {{ section.settings.height_desktop }}px;
      --margin-top-desktop: {{ section.settings.margin_top }}px;
      --margin-bottom-desktop: {{ section.settings.margin_bottom }}px;
      --tagline-size-desktop: {{ section.settings.tagline_size }}px;
      --heading-size-desktop: {{ section.settings.heading_size }}px;
      --description-size-desktop: {{ section.settings.description_size }}px;
    }
  }
  #parallax-video-{{ section.id }} .parallax-video__content-wrapper {
    --content-alignment-vertical: {{ section.settings.content_position_vertical }};
    --content-alignment-horizontal: {{ section.settings.content_position_horizontal }};
    --text-alignment: {{ section.settings.text_alignment }};
    --content-bg-color-rgb: {{ section.settings.content_bg_color.red }}, {{ section.settings.content_bg_color.green }}, {{ section.settings.content_bg_color.blue }};
    --content-bg-opacity: {{ section.settings.content_bg_opacity | divided_by: 100.0 }};
    --content-border-radius: {{ section.settings.content_border_radius }}px;
    --content-padding: {{ section.settings.content_padding_mobile }}px;
    --content-max-width: {{ section.settings.content_max_width }}px;
    --glass-blur: {{ section.settings.glass_blur }}px;
    --glass-border-opacity: {{ section.settings.glass_border_opacity | divided_by: 100.0 }};
    --glass-shadow-opacity: {{ section.settings.glass_shadow_opacity | divided_by: 100.0 }};
    --btn-bg: {{ section.settings.btn_bg_color }};
    --btn-bg-hover: {{ section.settings.btn_bg_color_hover }};
    --btn-text: {{ section.settings.btn_text_color }};
    --btn-text-hover: {{ section.settings.btn_text_color_hover }};
    --btn-border: {{ section.settings.btn_border_color }};
    --btn-border-hover: {{ section.settings.btn_border_color_hover }};
    --icon-size-desktop: {{ section.settings.icon_size_desktop }}px;
    --btn-border-hover: {{ section.settings.btn_border_color_hover }};
    --icon-size-desktop: {{ section.settings.icon_size_desktop }}px;
    --icon-size-mobile: {{ section.settings.icon_size_mobile }}px;
    {%- case section.settings.icon_color_filter -%}
      {%- when 'white' -%}
        --icon-filter: brightness(0) invert(1);
      {%- when 'black' -%}
        --icon-filter: brightness(0);
      {%- else -%}
        --icon-filter: none;
    {%- endcase -%}
  }
  @media screen and (min-width: 768px) {
    #parallax-video-{{ section.id }} .parallax-video__content-wrapper {
      --content-padding: {{ section.settings.content_padding }}px;
    }
  }
{%- endstyle -%}

<section 
  id="parallax-video-{{ section.id }}" 
  class="parallax-video-section parallax--{{ section.settings.parallax_style }}"
  data-section-id="{{ section.id }}"
  data-parallax-style="{{ section.settings.parallax_style }}"
>
  <!-- Background Container -->
  <div class="parallax-video__bg-container">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag:
        image_size: '2000x',
        autoplay: true,
        loop: true,
        muted: true,
        controls: false,
        playsinline: true,
        class: 'parallax-video__bg-media'
      }}
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag:
        class: 'parallax-video__bg-media',
        loading: 'lazy',
        widths: '600, 800, 1000, 1200, 1600, 2000'
      }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'parallax-video__bg-media' }}
    {%- endif -%}
  </div>

  <!-- Overlay -->
  <div class="parallax-video__overlay" style="background-color: var(--overlay-color); opacity: var(--overlay-opacity);"></div>

  <!-- Content -->
  <div class="parallax-video__content-wrapper">
    <div class="parallax-video__content {% if section.settings.enable_glass_effect %}glass-effect{% endif %}" data-align="{{ section.settings.text_alignment }}">
      {%- if section.settings.icon != blank -%}
        <div class="parallax-video__icon">
            {{ section.settings.icon | image_url: width: 200 | image_tag: loading: 'lazy' }}
        </div>
      {%- endif -%}

      {%- if section.settings.tagline != blank -%}
        <span class="parallax-video__tagline">{{ section.settings.tagline }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="parallax-video__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="parallax-video__description">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <div class="parallax-video__btn-wrapper">
          {%- if section.settings.button_style == 'circle' -%}
            <a href="{{ section.settings.button_link }}" class="button-circle parallax-video__btn" aria-label="{{ section.settings.button_label }}">
              <span class="button__text">{{ section.settings.button_label }}</span>
              <span class="button-new__icon-container">
                <span class="button-new__icon-wrapper">
                  {% render 'icons-new', icon: 'arrow-right' %}
                </span>
              </span>
            </a>
          {%- else -%}
            <a href="{{ section.settings.button_link }}" class="button-new button--{{ section.settings.button_style }} parallax-video__btn">
              {{ section.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.secondary_text != blank or section.settings.secondary_link_text != blank -%}
        <div class="parallax-video__secondary-link">
            {%- if section.settings.secondary_text != blank -%}
                {{ section.settings.secondary_text }}
            {%- endif -%}
            {%- if section.settings.secondary_link_text != blank and section.settings.secondary_link != blank -%}
                <a href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_link_text }} ›</a>
            {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- GSAP Script for Advanced Parallax -->
<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const style = '{{ section.settings.parallax_style }}';

    function initParallax() {
      if (style !== 'advanced') return;
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

      const section = document.querySelector(`#parallax-video-${sectionId}`);
      if (!section) return;

      const bgMedia = section.querySelector('.parallax-video__bg-media');
      
      // Animate background movement
      gsap.fromTo(bgMedia, 
        { yPercent: -50 },
        {
          yPercent: 50,
          ease: "none",
          scrollTrigger: {
            trigger: section,
            start: "top bottom", 
            end: "bottom top",
            scrub: true
          }
        }
      );
    }

    // Init
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initParallax);
    } else {
      initParallax();
    }
    
    document.addEventListener('shopify:section:load', (e) => {
      if(e.detail.sectionId === sectionId) initParallax();
    });
  })();
</script>

