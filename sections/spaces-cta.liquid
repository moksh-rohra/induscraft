{% style %}
    /* Bristone Font */
    @font-face {
        font-family: 'Bristone';
        src: url({{ 'Bristone Reg.otf' | asset_url }}) format('opentype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
    }

    .spaces-cta-{{ section.id }} {
        position: relative;
        width: 100%;
        min-height: {{ section.settings.mobile_height }}px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
        color: {{ section.settings.text_color }};
        padding-top: {{ section.settings.padding_top_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
        padding-left: 20px;
        padding-right: 20px;
        max-width: {{ section.settings.section_max_width }}%;
        margin: 0 auto;
        border-radius: {{ section.settings.border_radius }}px;
    }

    /* Background Image */
    .spaces-cta__bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    /* Overlay */
    .spaces-cta__overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: #000;
        opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
        z-index: 1;
    }

    /* Content */
    .spaces-cta__content {
        position: relative;
        z-index: 2;
        max-width: {{ section.settings.content_max_width }}px;
        width: 100%;
        padding: 0 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 30px;
    }

    .spaces-cta-{{ section.id }} .spaces-cta__heading {
        margin: 0;
        line-height: 1.2;
        font-weight: 500;
        color: currentColor;
        font-size: {{ section.settings.heading_size_mobile }}px;
        {%- if section.settings.use_bristone_font -%}
        font-family: 'Bristone', cursive;
        {%- endif -%}
    }

    .spaces-cta__btn {
        min-width: 220px;
    }



    /* Desktop Styles */
    @media screen and (min-width: 768px) {
        .spaces-cta-{{ section.id }} {
            min-height: {{ section.settings.desktop_height }}px;
            padding-top: {{ section.settings.padding_top_desktop }}px;
            padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
        }

        .spaces-cta-{{ section.id }} .spaces-cta__heading {
            font-size: {{ section.settings.heading_size_desktop }}px;
        }

        .spaces-cta__btn {
            font-size: 18px;
            padding: 18px 48px;
        }
    }
{% endstyle %}

<div class="spaces-cta-{{ section.id }}">
    {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 3000 | image_tag: 
            class: 'spaces-cta__bg', 
            widths: '550, 750, 1100, 1500, 2000, 3000',
            sizes: '100vw'
        }}
    {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'spaces-cta__bg placeholder-svg' }}
    {%- endif -%}

    <div class="spaces-cta__overlay"></div>

    <div class="spaces-cta__content">
        {%- if section.settings.heading != blank -%}
            <h2 class="spaces-cta__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.btn_label != blank -%}
            <a href="{{ section.settings.btn_link }}" class="button-new button--{{ section.settings.button_type }} spaces-cta__btn">
                {{ section.settings.btn_label }}
            </a>
        {%- endif -%}
    </div>
</div>

{% schema %}
{
    "name": "Spaces CTA",
    "tag": "section",
    "class": "spaces-cta-section",
    "settings": [
        {
            "type": "image_picker",
            "id": "image",
            "label": "Background Image"
        },
        {
            "type": "range",
            "id": "overlay_opacity",
            "min": 0,
            "max": 90,
            "step": 5,
            "unit": "%",
            "label": "Overlay Opacity",
            "default": 40
        },
        {
            "type": "header",
            "content": "Content"
        },
        {
            "type": "range",
            "id": "content_max_width",
            "min": 400,
            "max": 1200,
            "step": 20,
            "unit": "px",
            "label": "Content Max Width",
            "default": 800
        },
        {
            "type": "textarea",
            "id": "heading",
            "label": "Heading",
            "default": "Want to get your Own Space Designed?"
        },
        {
            "type": "range",
            "id": "heading_size_desktop",
            "min": 24,
            "max": 100,
            "step": 2,
            "unit": "px",
            "label": "Heading Size (Desktop)",
            "default": 64
        },
        {
            "type": "range",
            "id": "heading_size_mobile",
            "min": 20,
            "max": 60,
            "step": 2,
            "unit": "px",
            "label": "Heading Size (Mobile)",
            "default": 36
        },
        {
            "type": "checkbox",
            "id": "use_bristone_font",
            "label": "Use Bristone Font",
            "default": false
        },
        {
            "type": "text",
            "id": "btn_label",
            "label": "Button Label",
            "default": "Book a Consultation"
        },
        {
            "type": "url",
            "id": "btn_link",
            "label": "Button Link"
        },
        {
            "type": "select",
            "id": "button_type",
            "label": "Button Type",
            "options": [
                { "value": "primary", "label": "Primary" },
                { "value": "secondary", "label": "Secondary" }
            ],
            "default": "primary"
        },
        {
            "type": "header",
            "content": "Layout"
        },
        {
            "type": "range",
            "id": "desktop_height",
            "min": 300,
            "max": 1000,
            "step": 50,
            "unit": "px",
            "label": "Desktop Height",
            "default": 600
        },
        {
            "type": "range",
            "id": "section_max_width",
            "min": 50,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Section Max Width",
            "default": 100
        },
        {
            "type": "range",
            "id": "border_radius",
            "min": 0,
            "max": 40,
            "step": 2,
            "unit": "px",
            "label": "Border Radius",
            "default": 0
        },
        {
            "type": "range",
            "id": "mobile_height",
            "min": 200,
            "max": 800,
            "step": 50,
            "unit": "px",
            "label": "Mobile Height",
            "default": 400
        },
        {
            "type": "range",
            "id": "padding_top_desktop",
            "min": 0,
            "max": 100,
            "step": 5,
            "unit": "px",
            "label": "Padding Top (Desktop)",
            "default": 0
        },
        {
            "type": "range",
            "id": "padding_bottom_desktop",
            "min": 0,
            "max": 100,
            "step": 5,
            "unit": "px",
            "label": "Padding Bottom (Desktop)",
            "default": 0
        },
        {
            "type": "range",
            "id": "padding_top_mobile",
            "min": 0,
            "max": 100,
            "step": 5,
            "unit": "px",
            "label": "Padding Top (Mobile)",
            "default": 0
        },
        {
            "type": "range",
            "id": "padding_bottom_mobile",
            "min": 0,
            "max": 100,
            "step": 5,
            "unit": "px",
            "label": "Padding Bottom (Mobile)",
            "default": 0
        },
        {
            "type": "header",
            "content": "Colors"
        },
        {
            "type": "color",
            "id": "text_color",
            "label": "Text Color",
            "default": "#ffffff"
        }
    ],
    "presets": [
        {
            "name": "Spaces CTA"
        }
    ]
}
{% endschema %}
