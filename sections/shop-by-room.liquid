    ],
    "presets": [
        {
            "name": "Shop By Room",
            "blocks": [
                { "type": "room", "settings": { "title": "DINING" } },
                { "type": "room", "settings": { "title": "LIVING" } },
                { "type": "room", "settings": { "title": "OFFICE" } },
                { "type": "room", "settings": { "title": "LIGHTING" } }
