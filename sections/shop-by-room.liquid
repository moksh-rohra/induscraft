        },
        {
            "type": "range",
            "id": "card_title_size_mobile",
            "min": 14,
            "max": 40,
            "step": 1,
            "unit": "px",
            "label": "Card Title Size (Mobile)",
            "default": 24
        },
        {
            "type": "header",
            "content": "Spacing"
        },
        {
            "type": "range",
            "id": "padding_top_desktop",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "Padding Top (Desktop)",
            "default": 60
        },
        {
            "type": "range",
            "id": "padding_bottom_desktop",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "Padding Bottom (Desktop)",
            "default": 60
        },
        {
            "type": "range",
            "id": "padding_top_mobile",
            "min": 0,
            "max": 80,
            "step": 4,
            "unit": "px",
            "label": "Padding Top (Mobile)",
            "default": 40
