{{ 'breadcrumbs.build.css' | asset_url | stylesheet_tag }}

{%- assign bg_image = section.settings.background_image -%}
{%- assign overlay_color = section.settings.overlay_color -%}
{%- assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0 -%}
{%- assign text_color = section.settings.text_color -%}
{%- assign title_size_d = section.settings.title_size_desktop -%}
{%- assign title_size_m = section.settings.title_size_mobile -%}
{%- assign section_height_d = section.settings.section_height_desktop -%}
{%- assign section_height_m = section.settings.section_height_mobile -%}
{%- assign border_radius = section.settings.border_radius -%}
{%- assign accent_color = section.settings.accent_line_color -%}
{%- assign accent_width = section.settings.accent_line_width -%}
{%- assign show_breadcrumb = section.settings.show_breadcrumb -%}
{%- assign use_bristone = section.settings.use_bristone_font -%}
{%- assign content_position = section.settings.content_position -%}
{%- assign padding_top = section.settings.padding_top -%}
{%- assign padding_bottom = section.settings.padding_bottom -%}

<section
  id="collection-title-{{ section.id }}"
  class="collection-title-section"
  style="
    --ct-text-color: {{ text_color }};
    --ct-title-size-d: {{ title_size_d }}px;
    --ct-title-size-m: {{ title_size_m }}px;
    --ct-height-d: {{ section_height_d }}px;
    --ct-height-m: {{ section_height_m }}px;
    --ct-border-radius: {{ border_radius }}px;
    --ct-overlay-color: {{ overlay_color }};
    --ct-overlay-opacity: {{ overlay_opacity }};
    --ct-accent-color: {{ accent_color }};
    --ct-accent-width: {{ accent_width }}px;
    --ct-padding-top: {{ padding_top }}px;
    --ct-padding-bottom: {{ padding_bottom }}px;
  "
>
  <div class="collection-title__wrapper">
    {%- if bg_image != blank -%}
      {{ bg_image | image_url: width: 2000 | image_tag: loading: 'eager', class: 'collection-title__image' }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'collection-title__image collection-title__placeholder' }}
    {%- endif -%}

    <div class="collection-title__overlay"></div>

    <div class="collection-title__content collection-title__content--{{ content_position }}">
      {%- if show_breadcrumb -%}
        <nav class="collection-title__breadcrumb" aria-label="{{ 'general.breadcrumbs.title' | t | escape }}">
          <div class="collection-title__breadcrumb-container">
            <a class="collection-title__crumb-link" href="{{ routes.root_url }}">
              {{ 'general.breadcrumbs.home' | t }}
            </a>
            <span class="collection-title__crumb-sep" aria-hidden="true">/</span>
            <span class="collection-title__crumb-current">{{ collection.title }}</span>
          </div>
        </nav>
      {%- else -%}
        <h1 class="collection-title__heading {% if use_bristone %}collection-title__heading--bristone{% endif %}">
          {{ collection.title }}
        </h1>
      {%- endif -%}

      {%- if section.settings.show_accent_line -%}
        <div class="collection-title__accent-line"></div>
      {%- endif -%}
    </div>
  </div>
</section>

{% if section.settings.hide_on_featured_product %}
<script>
  (function() {
    var params = new URLSearchParams(window.location.search);
    if (params.get('featured') === '1') {
      var el = document.getElementById('collection-title-{{ section.id }}');
      if (el) el.style.display = 'none';
    }
  })();
</script>
{% endif %}

<style>
  .collection-title-section {
    padding-top: var(--ct-padding-top, 0);
    padding-bottom: var(--ct-padding-bottom, 0);
  }

  .collection-title__wrapper {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--ct-height-d, 280px);
    border-radius: var(--ct-border-radius, 20px);
    width: calc(100% - 32px);
    margin-left: auto;
    margin-right: auto;
  }

  .collection-title__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .collection-title__placeholder {
    background: #333;
  }

  .collection-title__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--ct-overlay-color, #000);
    opacity: var(--ct-overlay-opacity, 0.3);
    z-index: 1;
  }

  .collection-title__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 30px 20px;
    width: 100%;
  }

  .collection-title__content--center {
    align-items: center;
    text-align: center;
  }

  .collection-title__content--left {
    align-items: flex-start;
    text-align: left;
  }

  .collection-title__content--right {
    align-items: flex-end;
    text-align: right;
  }

  /* Heading */
  .collection-title__heading {
    margin: 0;
    color: var(--ct-text-color, #fff);
    font-size: var(--ct-title-size-d, 40px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    line-height: 1.2;
  }

  .collection-title__heading--bristone {
    font-family: 'Bristone', var(--heading-font-family) !important;
  }

  /* Breadcrumb */
  .collection-title__breadcrumb-container {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Bristone', var(--heading-font-family);
    font-size: var(--ct-title-size-d, 35px);
    color: var(--ct-text-color, #fff);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .collection-title__crumb-link {
    color: var(--ct-text-color, #fff);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .collection-title__crumb-link:hover {
    opacity: 0.7;
  }

  .collection-title__crumb-sep {
    color: var(--ct-text-color, #fff);
    opacity: 0.7;
  }

  .collection-title__crumb-current {
    color: var(--ct-text-color, #fff);
    opacity: 0.85;
  }

  /* Accent Line */
  .collection-title__accent-line {
    margin-top: 14px;
    width: var(--ct-accent-width, 80px);
    height: 3px;
    background-color: var(--ct-accent-color, #c88a3a);
    border-radius: 2px;
  }

  /* Responsive */
  @media (min-width: 769px) {
    .collection-title__wrapper {
      width: calc(100% - 120px);
      margin-left: 60px;
      margin-right: 60px;
    }
  }

  @media (max-width: 768px) {
    .collection-title__wrapper {
      min-height: var(--ct-height-m, 160px);
    }

    .collection-title__heading {
      font-size: var(--ct-title-size-m, 20px);
    }

    .collection-title__breadcrumb-container {
      font-size: var(--ct-title-size-m, 14px);
      gap: 6px;
    }

    .collection-title__accent-line {
      margin-top: 10px;
      height: 2px;
    }

    .collection-title__content {
      padding: 20px 15px;
    }
  }
</style>

{% schema %}
{
  "name": "Collection Title",
  "class": "collection-title-wrapper",
  "settings": [
    { "type": "header", "content": "Background Image" },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image Border Radius",
      "default": 20
    },
    { "type": "header", "content": "Overlay" },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 30
    },
    { "type": "header", "content": "Title / Breadcrumb" },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show as Breadcrumb (Home / Collection)",
      "default": true,
      "info": "If unchecked, shows only the collection name as a heading"
    },
    {
      "type": "checkbox",
      "id": "use_bristone_font",
      "label": "Use Bristone Font",
      "default": true,
      "info": "Applies to heading mode; breadcrumb always uses Bristone"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Title / Breadcrumb Size (Desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Title / Breadcrumb Size (Mobile)",
      "default": 14
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "header", "content": "Accent Line" },
    {
      "type": "checkbox",
      "id": "show_accent_line",
      "label": "Show Accent Line",
      "default": true
    },
    {
      "type": "color",
      "id": "accent_line_color",
      "label": "Accent Line Color",
      "default": "#c88a3a"
    },
    {
      "type": "range",
      "id": "accent_line_width",
      "min": 30,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Accent Line Width",
      "default": 80
    },
    { "type": "header", "content": "Section Size" },
    {
      "type": "range",
      "id": "section_height_desktop",
      "min": 100,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Section Height (Desktop)",
      "default": 280
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "min": 80,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Section Height (Mobile)",
      "default": 160
    },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 0
    },
    { "type": "header", "content": "Featured Product" },
    {
      "type": "checkbox",
      "id": "hide_on_featured_product",
      "label": "Hide when featured product is active",
      "default": true,
      "info": "Hides this section when URL contains ?featured=1 (featured product from URL)"
    }
  ],
  "templates": ["collection"],
  "presets": [
    {
      "name": "Collection Title"
    }
  ]
}
{% endschema %}
